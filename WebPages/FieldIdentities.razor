@page "/FieldIdentities"
@inject ILogger<FieldIdentities> logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IFieldAPIUtils Api

@if (identities == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <MudText Class="mt-4 mb-4" Typo="Typo.h6">Field Identities</MudText>
    <MudContainer Class="d-flex flex-row pa-0 mb-3">
        <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="AddIdentity">Add</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@(!_selectedIdentityIds.Any())" OnClick="DeleteSelectedIdentitiesAsync">Delete</MudButton>
    </MudContainer>

    <MudGrid Class="mt-2">
        <MudItem xs="2" md="1" Class="d-flex align-center">
            <MudCheckBox T="bool" Value="@AreAllIdentitiesSelected()" ValueChanged="@SetAllIdentitiesSelected" />
        </MudItem>
        <MudItem xs="10" md="4" Class="d-flex align-center">
            <MudText Typo="Typo.subtitle2">Name</MudText>
        </MudItem>
        <MudItem xs="10" md="6" />
        <MudItem xs="2" md="1" />
    </MudGrid>

    @foreach (FieldIdentity identity in identities)
    {
        <MudGrid Class="mt-2" @key="identity.MetaInfo?.ID">
            <MudItem xs="2" md="1" Class="d-flex align-center">
                <MudCheckBox T="bool" Value="@IsIdentitySelected(identity)" ValueChanged="@((bool selected) => SetIdentitySelected(identity, selected))" />
            </MudItem>
            <MudItem xs="10" md="4">
                <MudTextField @bind-Value="identity.Name" Required="true" />
            </MudItem>
            <MudItem xs="10" md="6" />
            <MudItem xs="2" md="1" Class="d-flex align-center justify-end">
                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => DeleteIdentityAsync(identity))" />
            </MudItem>
        </MudGrid>
    }

    <MudContainer Class="d-flex flex-row pa-0 mt-4">
        <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveAsync">Save</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync">Reload</MudButton>
    </MudContainer>
}

@code {
    private List<FieldIdentity>? identities;
    private readonly HashSet<Guid> _selectedIdentityIds = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            identities = (List<FieldIdentity>)await Api.ClientField.GetAllFieldIdentityAsync();
            identities = identities
                .Where(identity => identity?.MetaInfo?.ID != null)
                .OrderBy(identity => identity.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
            _selectedIdentityIds.Clear();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load field identities");
            Snackbar.Add("Impossible to load field identities", Severity.Error);
            identities = [];
        }
    }

    private void AddIdentity()
    {
        DateTimeOffset now = DateTimeOffset.UtcNow;
        identities ??= [];
        identities.Add(new FieldIdentity
        {
            MetaInfo = new MetaInfo { ID = Guid.NewGuid(), HttpHostName = Api.HostNameField, HttpHostBasePath = Api.HostBasePathField, HttpEndPoint = "FieldIdentity/" },
            Name = "new field identity",
            CreationDate = now,
            LastModificationDate = now
        });
    }

    private async Task SaveAsync()
    {
        if (identities == null || !TryValidateIdentities())
        {
            return;
        }

        try
        {
            List<Guid> existingIds = ((IEnumerable<Guid>)await Api.ClientField.GetAllFieldIdentityIdAsync()).ToList();
            foreach (FieldIdentity identity in identities)
            {
                EnsureMetaInfo(identity);
                if (existingIds.Contains(identity.MetaInfo!.ID))
                {
                    await Api.ClientField.PutFieldIdentityByIdAsync(identity.MetaInfo.ID, identity);
                }
                else
                {
                    await Api.ClientField.PostFieldIdentityAsync(identity);
                }
            }

            Snackbar.Add("Saved field identities", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to save field identities");
            Snackbar.Add("Impossible to save field identities", Severity.Error);
        }
    }

    private async Task DeleteSelectedIdentitiesAsync()
    {
        if (identities == null)
        {
            return;
        }

        foreach (FieldIdentity identity in identities.Where(IsIdentitySelected).ToList())
        {
            await DeleteIdentityAsync(identity);
        }
    }

    private async Task DeleteIdentityAsync(FieldIdentity identity)
    {
        Guid? id = identity.MetaInfo?.ID;
        if (identities == null || id == null || id == Guid.Empty)
        {
            return;
        }

        try
        {
            if (await ConfirmDeletionAsync(identity))
            {
                try
                {
                    await Api.ClientField.DeleteFieldIdentityByIdAsync(id.Value);
                }
                catch (ApiException ex) when (ex.StatusCode == 404)
                {
                    // Locally added unsaved item.
                }
                identities.Remove(identity);
                _selectedIdentityIds.Remove(id.Value);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete field identity");
            Snackbar.Add("Impossible to delete field identity", Severity.Error);
        }
    }

    private async Task<bool> ConfirmDeletionAsync(FieldIdentity identity)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Delete",
            $"Delete field identity '{identity.Name ?? identity.MetaInfo?.ID.ToString()}'?",
            yesText: "Delete",
            cancelText: "Cancel",
            options: new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall });
        return result == true;
    }

    private bool TryValidateIdentities()
    {
        if (identities == null)
        {
            return false;
        }
        if (identities.Any(identity => string.IsNullOrWhiteSpace(identity.Name)))
        {
            Snackbar.Add("Field identity names cannot be empty", Severity.Warning);
            return false;
        }
        if (identities.GroupBy(identity => identity.Name!.Trim(), StringComparer.OrdinalIgnoreCase).Any(group => group.Count() > 1))
        {
            Snackbar.Add("Field identity names must be unique", Severity.Warning);
            return false;
        }
        return true;
    }

    private static void EnsureMetaInfo(FieldIdentity identity)
    {
        if (identity.MetaInfo == null || identity.MetaInfo.ID == Guid.Empty)
        {
            identity.MetaInfo = new MetaInfo { ID = Guid.NewGuid() };
        }
    }

    private bool IsIdentitySelected(FieldIdentity identity)
    {
        return identity.MetaInfo?.ID is Guid id && _selectedIdentityIds.Contains(id);
    }

    private void SetIdentitySelected(FieldIdentity identity, bool selected)
    {
        if (identity.MetaInfo?.ID is not Guid id || id == Guid.Empty)
        {
            return;
        }

        if (selected)
        {
            _selectedIdentityIds.Add(id);
        }
        else
        {
            _selectedIdentityIds.Remove(id);
        }
    }

    private bool AreAllIdentitiesSelected()
    {
        return identities?.Count > 0 && identities.All(IsIdentitySelected);
    }

    private void SetAllIdentitiesSelected(bool selected)
    {
        _selectedIdentityIds.Clear();
        if (selected && identities != null)
        {
            foreach (FieldIdentity identity in identities)
            {
                if (identity.MetaInfo?.ID is Guid id && id != Guid.Empty)
                {
                    _selectedIdentityIds.Add(id);
                }
            }
        }
    }
}
