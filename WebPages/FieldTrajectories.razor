    private readonly record struct Vector3(double North, double East, double Tvd)
    {
        public static Vector3 operator +(Vector3 left, Vector3 right) => new(left.North + right.North, left.East + right.East, left.Tvd + right.Tvd);
        public static Vector3 operator -(Vector3 left, Vector3 right) => new(left.North - right.North, left.East - right.East, left.Tvd - right.Tvd);
        public static Vector3 operator *(Vector3 value, double factor) => new(value.North * factor, value.East * factor, value.Tvd * factor);
        public double Dot(Vector3 other) => North * other.North + East * other.East + Tvd * other.Tvd;
        public double DistanceTo(Vector3 other) => Math.Sqrt(Math.Pow(North - other.North, 2.0) + Math.Pow(East - other.East, 2.0) + Math.Pow(Tvd - other.Tvd, 2.0));
    }

    private sealed record TrajectoryPoint(double North, double East, double Tvd, double? MD, double? BoreholeRadius)
    {
        public Vector3 Position => new(North, East, Tvd);
        public bool HasSamePosition(TrajectoryPoint other) => AreClose(North, other.North) && AreClose(East, other.East) && AreClose(Tvd, other.Tvd);
    }

    private sealed record SegmentClosestApproach(double FirstParameter, double SecondParameter, double Distance);

    private sealed record ClosestApproachPoint(string Name, TrajectoryPoint Point, double? MD, double? BoreholeRadius);

    private sealed record ClosestApproachResult(ClosestApproachPoint First, ClosestApproachPoint Second, double Distance, double? Clearance);
