@page "/FieldTrajectories"
@inject ILogger<FieldTrajectories> logger
@inject ISnackbar Snackbar
@inject IFieldAPIUtils Api
@using System.Globalization
@using System.Net.Http.Json
@using System.Text.Json
@using FieldModelShared = NORCE.Drilling.Field.ModelShared

<MudUnitAndReferenceChoiceTag @ref="unitReference"
                              HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="OnUnitSystemNameChanged"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="OnDepthReferenceNameChanged"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.SeaWaterLevelDepthReferenceSource"
                              MeanSeaLevelDepthReferenceSource="@DataUtils.MeanSeaLevelDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@DataUtils.UpdatePositionReferenceName"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource"
                              >
    @if (fieldList == null || clusterList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <MudStack Spacing="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h5">Field Trajectories</MudText>
                        <MudText Typo="Typo.body2">All wellbore trajectories for the selected field, shown in 3D and as a horizontal projection.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="8" md="4">
                        <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                            @foreach (FieldModelShared.Field field in AvailableFields)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="ReloadSelectedFieldAsync" Disabled="@(selectedFieldId == null)">Reload</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudSelect Label="Type" T="string" Value="@selectedTrajectoryTypeFilter" ValueChanged="OnTrajectoryFilterChanged" ShrinkLabel>
                            <MudSelectItem T="string" Value="@TrajectoryTypeFilterAll">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@TrajectoryTypeFilterPlanned">Planned</MudSelectItem>
                            <MudSelectItem T="string" Value="@TrajectoryTypeFilterActual">Actual</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudCheckBox T="bool" Value="@definitiveTrajectoryOnly" ValueChanged="OnDefinitiveTrajectoryFilterChanged" Label="Definitive only" />
                    </MudItem>
                </MudGrid>
                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="4" md="3">
                        <MudNumericField @bind-Value="ellipseConfidenceFactor"
                                         Label="Confidence factor"
                                         Min="0.0"
                                         Max="1.0"
                                         Step="0.01"
                                         ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="CalculateUncertaintyEllipsesAsync"
                                   Disabled="@(trajectoryList.Count == 0 || isLoadingTrajectories || isCalculatingEllipses)">
                            Calculate Ellipses
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   OnClick="ClearUncertaintyEllipses"
                                   Disabled="@(ellipseResultsByTrajectory.Count == 0 || isCalculatingEllipses)">
                            Clear Ellipses
                        </MudButton>
                    </MudItem>
                    @if (isCalculatingEllipses)
                    {
                        <MudItem xs="12" md="3">
                            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mt-4" />
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@errorMessage</MudAlert>
            }
            else if (isLoadingTrajectories)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Loading trajectories for the selected field.</MudAlert>
            }
            else if (selectedFieldId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a field to display its wellbore trajectories.</MudAlert>
            }
            else if (trajectoryList.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No trajectories were found for the selected field.</MudAlert>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">3D View</MudText>
                            <Scatter3DPlot XUnit="PositionDrilling"
                                           YUnit="PositionDrilling"
                                           ZUnit="DepthDrilling"
                                           NameList="@Plot3DNames"
                                           ModeFlagList="@Plot3DModeFlags"
                                           ColorList="@Plot3DColors"
                                           MarkerSizeList="@PlotMarkerSizes"
                                           XValuesList="@Plot3DEastValuesList"
                                           YValuesList="@Plot3DNorthValuesList"
                                           ZValuesList="@Plot3DTvdValuesList"
                                           XAxisTitle="Easting"
                                           YAxisTitle="Northing"
                                           ZAxisTitle="TVD"
                                           PlotTitle="Field trajectories"
                                           PlotHeight="600"
                                           ZAxisReversed="true"
                                           XAxisUsesPositionReference="true"
                                           YAxisUsesPositionReference="true"
                                           ZAxisUsesDepthReference="true"
                                           XAxisPositionDirection="@PositionDirectionType.East"
                                           YAxisPositionDirection="@PositionDirectionType.North"
                                           ShowLegends="@Plot3DShowLegends"
                                           LegendLinkedTraceIds="@Plot3DLegendLinkedTraceIds"
                                           LegendControlsLinkedTraces="@Plot3DLegendControlsLinkedTraces"
                                           LegendTraceKinds="@Plot3DLegendTraceKinds"
                                           SelectableTraceIds="@Plot3DSelectableTraceIds"
                                           SelectedTraceIds="@Plot3DSelectedTraceIds"
                                           TraceIdClicked="OnTrajectoryTraceClicked" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">Horizontal Projection</MudText>
                            <ScatterPlot XUnit="PositionDrilling"
                                         YUnit="PositionDrilling"
                                         NameList="@PlotHorizontalNames"
                                         ModeFlagList="@PlotHorizontalModeFlags"
                                         ColorList="@PlotHorizontalColors"
                                         XValuesList="@PlotHorizontalEastValuesList"
                                         YValuesList="@PlotHorizontalNorthValuesList"
                                         XAxisTitle="Easting"
                                         YAxisTitle="Northing"
                                         PlotTitle="Horizontal projection"
                                         PlotHeight="600"
                                         AspectRatio="1"
                                         XAxisUsesPositionReference="true"
                                         YAxisUsesPositionReference="true"
                                         XAxisPositionDirection="@PositionDirectionType.East"
                                         YAxisPositionDirection="@PositionDirectionType.North"
                                         ShowLegends="@PlotHorizontalShowLegends" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6">Closest Approach</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ClearClosestApproachSelection" Disabled="@(selectedTrajectoryIds.Count == 0 && closestApproachResult == null)">Clear</MudButton>
                        </MudStack>
                        <MudText Typo="Typo.body2">Click two trajectories in the 3D view to calculate the closest centerline approach. Start MD is applied independently to each trajectory.</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6" md="4">
                                <MudTextField T="string"
                                              Label="Start MD"
                                              Variant="Variant.Outlined"
                                              ShrinkLabel
                                              Clearable="true"
                                              Value="@closestApproachStartMdText"
                                              ValueChanged="OnClosestApproachStartMdTextChanged"
                                              Validation="@(new Func<string?, string?>(ValidateClosestApproachStartMd))"
                                              Adornment="Adornment.End"
                                              AdornmentText="@closestApproachDepthUnitLabel" />
                            </MudItem>
                        </MudGrid>
                        @if (selectedTrajectoryIds.Count > 0)
                        {
                            <MudText Typo="Typo.body2">Selected: @SelectedTrajectoryText</MudText>
                        }
                        @if (selectedTrajectoryIds.Count == 2 && closestApproachStartMd.HasValue && closestApproachResult == null)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No common trajectory portion is available at or beyond the selected start MD.</MudAlert>
                        }
                        @if (closestApproachResult != null)
                        {
                            <MudGrid>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">Centerline distance</MudText>
                                    <MudText Typo="Typo.body2">@FormatDistance(closestApproachResult.Distance)</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">Borehole clearance</MudText>
                                    <MudText Typo="Typo.body2">@FormatNullableDistance(closestApproachResult.Clearance)</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">@closestApproachResult.First.Name</MudText>
                                    <MudText Typo="Typo.body2">MD @FormatReferencedDepth(closestApproachResult.First.MD), borehole radius @FormatNullableDistance(closestApproachResult.First.BoreholeRadius)</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">@closestApproachResult.Second.Name</MudText>
                                    <MudText Typo="Typo.body2">MD @FormatReferencedDepth(closestApproachResult.Second.MD), borehole radius @FormatNullableDistance(closestApproachResult.Second.BoreholeRadius)</MudText>
                                </MudItem>
                            </MudGrid>
                        }
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Legend</MudText>
                    <MudGrid>
                        @foreach (var trace in plotTraces.Where(trace => trace.ShowLegend && trace.IsSelectable && trace.TrajectoryId != null))
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <input type="color"
                                           value="@GetColorPickerValue(trace.Color)"
                                           title="Select color"
                                           style="width:32px;height:28px;border:0;background:transparent;padding:0;cursor:pointer;"
                                           @onchange="@((ChangeEventArgs args) => SetTraceColor(trace, args.Value?.ToString()))" />
                                    <MudText Typo="Typo.body2">@trace.Name</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        </MudStack>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    private List<FieldModelShared.Field>? fieldList;
    private List<FieldModelShared.Cluster>? clusterList;
    private List<FieldModelShared.TrajectoryLight> trajectoryLightList = [];
    private List<FieldModelShared.Trajectory> trajectoryList = [];
    private Guid? selectedFieldId;
    private string? errorMessage;
    private bool isLoadingTrajectories;
    private const string TrajectoryTypeFilterAll = "All";
    private const string TrajectoryTypeFilterPlanned = "Planned";
    private const string TrajectoryTypeFilterActual = "Actual";
    private string selectedTrajectoryTypeFilter = TrajectoryTypeFilterAll;
    private bool definitiveTrajectoryOnly;
    private bool isCalculatingEllipses;
    private double ellipseConfidenceFactor = 0.95;
    private MudUnitAndReferenceChoiceTag? unitReference;

    private List<PlotTrace> plotTraces = [];
    private readonly Dictionary<Guid, string> trajectoryColorsById = [];
    private Dictionary<Guid, List<FieldModelShared.SurveyStationEllipseResult>> ellipseResultsByTrajectory = [];
    private List<Guid> selectedTrajectoryIds = [];
    private ClosestApproachResult? closestApproachResult;
    private double? closestApproachStartMd;
    private string? closestApproachStartMdText;
    private string closestApproachDepthUnitLabel = string.Empty;
    private Guid? lastTrajectoryClickId;
    private long lastTrajectoryClickTimestamp;
    private const long DuplicateTrajectoryClickWindowMilliseconds = 1000;

    private List<string> PlotNames => plotTraces.Select(trace => trace.Name).ToList();
    private List<int> PlotModeFlags => plotTraces.Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotColors => plotTraces.Select(trace => trace.Color).ToList();
    private List<bool> PlotShowLegends => plotTraces.Select(trace => trace.ShowLegend).ToList();
    private List<double?> PlotMarkerSizes => plotTraces.Select(trace => trace.MarkerSize).ToList();
    private List<List<object>> NorthValuesList => plotTraces.Select(trace => trace.NorthValues).ToList();
    private List<List<object>> EastValuesList => plotTraces.Select(trace => trace.EastValues).ToList();
    private List<List<object>> TvdValuesList => plotTraces.Select(trace => trace.TvdValues).ToList();
    private List<string> Plot3DNames => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Name).ToList();
    private List<int> Plot3DModeFlags => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ModeFlag).ToList();
    private List<string> Plot3DColors => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Color).ToList();
    private List<bool> Plot3DShowLegends => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ShowLegend).ToList();
    private List<string?> Plot3DLegendLinkedTraceIds => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.TrajectoryId?.ToString("D")).ToList();
    private List<bool> Plot3DLegendControlsLinkedTraces => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ShowLegend && trace.TrajectoryId != null && trace.LegendTraceKind != PlotTraceKindOther).ToList();
    private List<string> Plot3DLegendTraceKinds => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.LegendTraceKind).ToList();
    private List<string?> Plot3DSelectableTraceIds => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.IsSelectable ? trace.TrajectoryId?.ToString("D") : null).ToList();
    private List<string> Plot3DSelectedTraceIds => selectedTrajectoryIds.Select(id => id.ToString("D")).ToList();
    private List<List<object>> Plot3DNorthValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> Plot3DEastValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.EastValues).ToList();
    private List<List<object>> Plot3DTvdValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.TvdValues).ToList();
    private List<string> PlotHorizontalNames => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Name).ToList();
    private List<int> PlotHorizontalModeFlags => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotHorizontalColors => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Color).ToList();
    private List<bool> PlotHorizontalShowLegends => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> PlotHorizontalNorthValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> PlotHorizontalEastValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.EastValues).ToList();
    private string SelectedTrajectoryText => string.Join(" -> ", selectedTrajectoryIds.Select(id => FindTrajectoryName(id)));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            logger.LogInformation("Trying to load list of Fields from client: {Host}", Api.HostNameField);
            Task<ICollection<FieldModelShared.Field>> fieldTask = Api.ClientField.GetAllFieldAsync();
            Task<ICollection<FieldModelShared.Cluster>> clusterTask = Api.ClientCluster.GetAllClusterAsync();
            fieldList = (await fieldTask).OrderBy(field => field.Name).ToList();
            clusterList = (await clusterTask).OrderBy(cluster => cluster.Name).ToList();
            selectedFieldId = null;
            FieldReferenceDatumUtils.Clear();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading fields");
            errorMessage = "Unable to load fields.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading fields");
            errorMessage = "Unable to load fields.";
            Snackbar.Add(errorMessage, Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            RefreshClosestApproachStartMdDisplay();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnUnitSystemNameChanged(string value)
    {
        DataUtils.UpdateUnitSystemName(value);
        RefreshClosestApproachStartMdDisplay();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDepthReferenceNameChanged(string value)
    {
        DataUtils.UpdateDepthReferenceName(value);
        RefreshClosestApproachStartMdDisplay();
        await InvokeAsync(StateHasChanged);
    }

    private List<FieldModelShared.Field> AvailableFields =>
        fieldList?
            .Where(field => field?.MetaInfo != null)
            .OrderBy(field => field.Name)
            .ToList() ?? [];

    private async Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId = fieldId;
        if (selectedFieldId is Guid selected)
        {
            await ApplySelectedFieldReferenceValuesAsync(selected);
            await LoadTrajectoriesAsync(selected);
        }
        else
        {
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
            FieldReferenceDatumUtils.Clear();
            RefreshClosestApproachStartMdDisplay();
            errorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadSelectedFieldAsync()
    {
        if (selectedFieldId is Guid fieldId)
        {
            await ApplySelectedFieldReferenceValuesAsync(fieldId);
            await LoadTrajectoriesAsync(fieldId);
        }
    }


    private async Task OnTrajectoryFilterChanged(string value)
    {
        selectedTrajectoryTypeFilter = string.IsNullOrWhiteSpace(value) ? TrajectoryTypeFilterAll : value;
        await ReloadCurrentSelectionAsync();
    }

    private async Task OnDefinitiveTrajectoryFilterChanged(bool value)
    {
        definitiveTrajectoryOnly = value;
        await ReloadCurrentSelectionAsync();
    }

    private bool MatchesTrajectoryFilters(FieldModelShared.TrajectoryLight trajectory)
    {
        bool typeMatches = selectedTrajectoryTypeFilter == TrajectoryTypeFilterAll ||
            string.Equals(trajectory.TrajectoryType.ToString(), selectedTrajectoryTypeFilter, StringComparison.OrdinalIgnoreCase);
        bool definitiveMatches = !definitiveTrajectoryOnly || trajectory.IsDefinitive;
        return typeMatches && definitiveMatches;
    }

    private async Task ReloadCurrentSelectionAsync()
    {
        if (selectedFieldId is Guid fieldId)
        {
            await ApplySelectedFieldReferenceValuesAsync(fieldId);
            await LoadTrajectoriesAsync(fieldId);
        }
    }

    private async Task ApplySelectedFieldReferenceValuesAsync(Guid fieldId)
    {
        FieldReferenceDatumUtils.Apply(
            await FieldReferenceDatumUtils.ResolveForFieldAsync(Api, fieldId, clusterList));
        RefreshClosestApproachStartMdDisplay();
    }

    private async Task LoadTrajectoriesAsync(Guid fieldId)
    {
        try
        {
            errorMessage = null;
            isLoadingTrajectories = true;
            ellipseResultsByTrajectory.Clear();
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
            await InvokeAsync(StateHasChanged);
            logger.LogInformation("Loading trajectory light data for field {FieldId}", fieldId);
            trajectoryLightList = (await Api.ClientTrajectory.GetAllTrajectoryLightAsync(fieldId: fieldId)).Where(MatchesTrajectoryFilters).OrderBy(trajectory => trajectory.Name).ToList();

            List<Task<FieldModelShared.Trajectory>> detailTasks = trajectoryLightList
                .Where(light => light?.MetaInfo != null && light.MetaInfo.ID != Guid.Empty)
                .Select(light => LoadTrajectoryWithSurveyStationsAsync(light.MetaInfo.ID))
                .ToList();

            trajectoryList = (await Task.WhenAll(detailTasks))
                .Where(trajectory => trajectory != null)
                .OrderBy(trajectory => trajectory.Name)
                .ToList();

            UpdatePlots();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading trajectories for field {FieldId}", fieldId);
            errorMessage = "Unable to load trajectories for the selected field.";
            Snackbar.Add(errorMessage, Severity.Error);
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading trajectories for field {FieldId}", fieldId);
            errorMessage = "Unable to load trajectories for the selected field.";
            Snackbar.Add(errorMessage, Severity.Error);
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
        }
        finally
        {
            isLoadingTrajectories = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<FieldModelShared.Trajectory> LoadTrajectoryWithSurveyStationsAsync(Guid trajectoryId)
    {
        FieldModelShared.Trajectory trajectory = await Api.ClientTrajectory.GetTrajectoryByIdAsync(trajectoryId);
        int chunkCount = await Api.HttpClientTrajectory.GetFromJsonAsync<int>($"Trajectory/{trajectoryId}/SurveyStations/ChunkCount");
        if (chunkCount <= 0)
        {
            trajectory.SurveyStationList ??= [];
            return trajectory;
        }

        List<FieldModelShared.SurveyStation> stations = [];
        for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
        {
            FieldModelShared.SurveyStationChunk? chunk = await Api.HttpClientTrajectory.GetFromJsonAsync<FieldModelShared.SurveyStationChunk>($"Trajectory/{trajectoryId}/SurveyStations/Chunks/{chunkIndex}");
            if (chunk?.SurveyStationList is { Count: > 0 } chunkStations)
            {
                stations.AddRange(chunkStations);
            }
        }

        trajectory.SurveyStationList = stations;
        return trajectory;
    }

    private void UpdatePlots()
    {
        ClearPlots();
        int colorIndex = 0;
        List<PlotTrace> nextPlotTraces = [];

        foreach (FieldModelShared.Trajectory trajectory in trajectoryList)
        {
            if (trajectory?.SurveyStationList == null || trajectory.SurveyStationList.Count == 0)
            {
                continue;
            }

            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];

            foreach (FieldModelShared.SurveyStation station in trajectory.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }

            if (northValues.Count < 2 || northValues.Count != eastValues.Count || northValues.Count != tvdValues.Count)
            {
                continue;
            }

            if (trajectory.MetaInfo?.ID is not Guid trajectoryId || trajectoryId == Guid.Empty)
            {
                continue;
            }

            string traceColor = GetTrajectoryColor(trajectoryId, colorIndex);

            nextPlotTraces.Add(new PlotTrace(
                string.IsNullOrWhiteSpace(trajectory.Name) ? "trajectory" : trajectory.Name,
                3,
                traceColor,
                true,
                2.0,
                trajectoryId,
                true,
                northValues,
                eastValues,
                tvdValues));

            if (ellipseResultsByTrajectory.TryGetValue(trajectoryId, out List<FieldModelShared.SurveyStationEllipseResult>? ellipseResults))
            {
                AddEllipseTraces(nextPlotTraces, trajectory.SurveyStationList, ellipseResults, traceColor, trajectoryId, trajectory.Name);
            }
            colorIndex++;
        }

        AppendClosestApproachOverlay(nextPlotTraces);
        plotTraces = nextPlotTraces;
    }

    private async Task OnTrajectoryTraceClicked(string trajectoryIdValue)
    {
        if (!Guid.TryParse(trajectoryIdValue, out Guid trajectoryId) || trajectoryId == Guid.Empty)
        {
            return;
        }

        if (!plotTraces.Any(trace => trace.ShowIn3D && trace.IsSelectable && trace.TrajectoryId == trajectoryId))
        {
            return;
        }

        long clickTimestamp = Environment.TickCount64;
        if (lastTrajectoryClickId == trajectoryId &&
            clickTimestamp - lastTrajectoryClickTimestamp < DuplicateTrajectoryClickWindowMilliseconds)
        {
            return;
        }

        lastTrajectoryClickId = trajectoryId;
        lastTrajectoryClickTimestamp = clickTimestamp;

        if (selectedTrajectoryIds.Count == 1 && selectedTrajectoryIds[0] == trajectoryId)
        {
            Snackbar.Add("Select a different trajectory for closest approach.", Severity.Info);
            return;
        }

        if (selectedTrajectoryIds.Count >= 2)
        {
            selectedTrajectoryIds.Clear();
            closestApproachResult = null;
        }

        selectedTrajectoryIds.Add(trajectoryId);

        if (selectedTrajectoryIds.Count == 2)
        {
            CalculateSelectedClosestApproach(true);
        }

        UpdatePlots();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnClosestApproachStartMdTextChanged(string? startMdText)
    {
        closestApproachStartMdText = startMdText;
        if (string.IsNullOrWhiteSpace(startMdText))
        {
            closestApproachStartMd = null;
        }
        else if (TryParseDepth(startMdText, out double startMdInUserUnit) && unitReference != null)
        {
            double convertedMd = ConvertDisplayedDepthToWgs84(startMdInUserUnit);
            if (!double.IsNaN(convertedMd))
            {
                closestApproachStartMd = convertedMd;
            }
        }

        if (selectedTrajectoryIds.Count == 2)
        {
            CalculateSelectedClosestApproach(false);
            UpdatePlots();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RefreshClosestApproachStartMdDisplay()
    {
        if (unitReference == null)
        {
            return;
        }

        closestApproachDepthUnitLabel = GetReferencedDepthUnitLabel();
        closestApproachStartMdText = closestApproachStartMd.HasValue
            ? FormatReferencedDepthValue(closestApproachStartMd.Value)
            : null;
    }

    private double ConvertDisplayedDepthToWgs84(double displayedDepth)
    {
        if (unitReference == null)
        {
            return double.NaN;
        }

        if (IsSeaWaterLevelDepthReference())
        {
            double depthInSi = unitReference.ToSI(displayedDepth, "DepthDrilling");
            return depthInSi - GetSeaWaterLevelDepthReference();
        }

        return unitReference.ToWGS84DepthSI(displayedDepth, "DepthDrilling");
    }

    private string FormatReferencedDepthValue(double wgs84Depth)
    {
        if (unitReference == null)
        {
            return string.Empty;
        }

        if (IsSeaWaterLevelDepthReference())
        {
            double referencedDepth = wgs84Depth + GetSeaWaterLevelDepthReference();
            return unitReference.FromSI(referencedDepth, "DepthDrilling", false);
        }

        return unitReference.FromWGS84DepthSI(wgs84Depth, "DepthDrilling", false);
    }

    private string GetReferencedDepthUnitLabel()
    {
        if (unitReference == null)
        {
            return string.Empty;
        }

        return IsSeaWaterLevelDepthReference()
            ? $"{unitReference.GetUnitLabel("DepthDrilling")}SL-WL"
            : unitReference.GetDepthUnitLabel("DepthDrilling");
    }

    private static bool IsSeaWaterLevelDepthReference() =>
        string.Equals(
            DataUtils.UnitAndReferenceParameters.DepthReferenceName,
            "Sea/Water Level",
            StringComparison.OrdinalIgnoreCase);

    private static double GetSeaWaterLevelDepthReference() =>
        DataUtils.SeaWaterLevelDepthReferenceSource.SeaWaterLevelDepthReference ??
        DataUtils.MeanSeaLevelDepthReferenceSource.MeanSeaLevelDepthReference ??
        0.0;

    private string FormatReferencedDepth(double? value)
    {
        if (value is not { } depth || unitReference == null)
        {
            return "N/A";
        }

        string convertedValue = FormatReferencedDepthValue(depth);
        string unitLabel = GetReferencedDepthUnitLabel();
        return string.IsNullOrWhiteSpace(convertedValue)
            ? "N/A"
            : $"{convertedValue} {unitLabel}".Trim();
    }

    private static bool TryParseDepth(string value, out double result) =>
        double.TryParse(value, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.CurrentCulture, out result) ||
        double.TryParse(value, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out result);

    private static string? ValidateClosestApproachStartMd(string? value) =>
        string.IsNullOrWhiteSpace(value) || TryParseDepth(value, out _)
            ? null
            : "Invalid depth.";

