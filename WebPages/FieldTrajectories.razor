    private async Task CalculateUncertaintyEllipsesAsync()
    {
        if (trajectoryList.Count == 0)
        {
            return;
        }

        try
        {
            isCalculatingEllipses = true;
            ellipseResultsByTrajectory.Clear();
            await InvokeAsync(StateHasChanged);

            Dictionary<Guid, List<FieldModelShared.SurveyStationEllipseResult>> nextEllipseResultsByTrajectory = [];
            foreach (FieldModelShared.Trajectory trajectory in trajectoryList)
            {
                if (trajectory.MetaInfo?.ID is not Guid trajectoryId ||
                    trajectory.SurveyStationList is not { Count: > 0 } surveyStations)
                {
                    continue;
                }

                FieldModelShared.SurveyStationEllipseCalculation order = new()
                {
                    MetaInfo = new FieldModelShared.MetaInfo { ID = Guid.NewGuid() },
                    Name = $"{trajectory.Name} uncertainty ellipses",
                    Description = string.Empty,
                    CreationDate = DateTimeOffset.UtcNow,
                    LastModificationDate = DateTimeOffset.UtcNow,
                    ConfidenceFactor = ellipseConfidenceFactor,
                    SurveyStationList = surveyStations
                };

                HttpResponseMessage response = await Api.HttpClientTrajectory.PostAsJsonAsync("SurveyStationEllipseCalculation", order);
                response.EnsureSuccessStatusCode();
                FieldModelShared.SurveyStationEllipseCalculation? result = await response.Content.ReadFromJsonAsync<FieldModelShared.SurveyStationEllipseCalculation>();
                if (result?.SurveyStationEllipseResultList is { Count: > 0 } ellipseResults)
                {
                    nextEllipseResultsByTrajectory[trajectoryId] = ellipseResults.ToList();
                }
            }

            ellipseResultsByTrajectory = nextEllipseResultsByTrajectory;
            UpdatePlots();
            if (ellipseResultsByTrajectory.Count == 0)
            {
                Snackbar.Add("No uncertainty ellipses could be calculated.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while calculating uncertainty ellipses");
            Snackbar.Add("Problem while calculating uncertainty ellipses: " + ex.Message, Severity.Error);
        }
        finally
        {
            isCalculatingEllipses = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ClearUncertaintyEllipses()
    {
        ellipseResultsByTrajectory.Clear();
        UpdatePlots();
    }

    private static void AddEllipseTraces(
        List<PlotTrace> traces,
        ICollection<FieldModelShared.SurveyStation> surveyStations,
        IReadOnlyList<FieldModelShared.SurveyStationEllipseResult> ellipseResults,
        string color,
        Guid trajectoryId,
        string? trajectoryName)
    {
        bool horizontalLegendShown = false;
        bool perpendicularLegendShown = false;
        foreach ((FieldModelShared.SurveyStation station, FieldModelShared.SurveyStationEllipseResult result) in SelectEvenlySpacedEllipses(surveyStations, ellipseResults))
        {
            if (BuildHorizontalEllipseTrace(station, result.HorizontalEllipse, color, !horizontalLegendShown, trajectoryId, trajectoryName) is { } horizontalTrace)
            {
                traces.Add(horizontalTrace);
                horizontalLegendShown = true;
            }
            if (BuildPerpendicularEllipseTrace(station, result.PerpendicularEllipse, color, !perpendicularLegendShown, trajectoryId, trajectoryName) is { } perpendicularTrace)
            {
                traces.Add(perpendicularTrace);
                perpendicularLegendShown = true;
            }
        }
    }

    private static IReadOnlyList<(FieldModelShared.SurveyStation Station, FieldModelShared.SurveyStationEllipseResult Result)> SelectEvenlySpacedEllipses(
        ICollection<FieldModelShared.SurveyStation> surveyStations,
        IReadOnlyList<FieldModelShared.SurveyStationEllipseResult> ellipseResults)
    {
        List<(FieldModelShared.SurveyStation Station, FieldModelShared.SurveyStationEllipseResult Result)> candidates = [];
        foreach (FieldModelShared.SurveyStationEllipseResult result in ellipseResults)
        {
            FieldModelShared.SurveyStation? station = FindStation(surveyStations, result.MD);
            if (station != null)
            {
                candidates.Add((station, result));
            }
        }

        if (candidates.Count <= MaxDisplayedUncertaintyEllipses)
        {
            return candidates;
        }

        List<(FieldModelShared.SurveyStation Station, FieldModelShared.SurveyStationEllipseResult Result)> ordered = candidates
            .OrderBy(candidate => candidate.Result.MD ?? candidate.Station.MD ?? candidate.Station.Abscissa ?? double.MaxValue)
            .ToList();
        HashSet<int> selectedIndexes = [];
        for (int sampleIndex = 0; sampleIndex < MaxDisplayedUncertaintyEllipses; sampleIndex++)
        {
            int sourceIndex = (int)Math.Round(sampleIndex * (ordered.Count - 1.0) / (MaxDisplayedUncertaintyEllipses - 1.0));
            selectedIndexes.Add(Math.Clamp(sourceIndex, 0, ordered.Count - 1));
        }
        selectedIndexes.Add(ordered.Count - 1);
        return selectedIndexes.Order().Select(index => ordered[index]).ToList();
    }

    private static FieldModelShared.SurveyStation? FindStation(ICollection<FieldModelShared.SurveyStation> surveyStations, double? md)
    {
        if (md is not { } definedMd)
        {
            return null;
        }

        return surveyStations
            .Where(station => station != null && (station.MD ?? station.Abscissa) is { })
            .OrderBy(station => Math.Abs(((station.MD ?? station.Abscissa) ?? double.MaxValue) - definedMd))
            .FirstOrDefault();
    }

    private static PlotTrace? BuildHorizontalEllipseTrace(FieldModelShared.SurveyStation station, FieldModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, Guid trajectoryId, string? trajectoryName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double major = semiMajor * Math.Cos(phi);
            double minor = semiMinor * Math.Sin(phi);
            double northOffset = major * Math.Cos(angle) - minor * Math.Sin(angle);
            double eastOffset = major * Math.Sin(angle) + minor * Math.Cos(angle);
            northValues.Add(centerNorth + northOffset);
            eastValues.Add(centerEast + eastOffset);
            tvdValues.Add(centerTvd);
        }

        return new PlotTrace($"{trajectoryName ?? "trajectory"} horizontal ellipses", 1, color, showLegend, 2.0, trajectoryId, false, northValues, eastValues, tvdValues, false, true, PlotTraceKindHorizontalEllipse);
    }

    private static PlotTrace? BuildPerpendicularEllipseTrace(FieldModelShared.SurveyStation station, FieldModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, Guid trajectoryId, string? trajectoryName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.Inclination is not double inclination ||
            station.Azimuth is not double azimuth ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        double cosA = Math.Cos(azimuth);
        double sinA = Math.Sin(azimuth);
        double cosI = Math.Cos(inclination);
        double sinI = Math.Sin(inclination);
        double cosO = Math.Cos(angle);
        double sinO = Math.Sin(angle);
        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double localX0 = semiMajor * Math.Cos(phi);
            double localY0 = semiMinor * Math.Sin(phi);
            double localX = localX0 * cosO - localY0 * sinO;
            double localY = localX0 * sinO + localY0 * cosO;
            northValues.Add(centerNorth + cosA * cosI * localX - sinA * localY);
            eastValues.Add(centerEast + sinA * cosI * localX + cosA * localY);
            tvdValues.Add(centerTvd - sinI * localX);
        }

        return new PlotTrace($"{trajectoryName ?? "trajectory"} perpendicular ellipses", 1, color, showLegend, 2.0, trajectoryId, false, northValues, eastValues, tvdValues, true, false, PlotTraceKindPerpendicularEllipse);
    }


    private static void AppendPoint(FieldModelShared.SurveyStation? point, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (point?.X is not { } north || point.Y is not { } east)
        {
            return;
        }

        double tvd = point.TVD ?? point.Z ?? 0.0;
        AppendPointValues(north, east, tvd, northValues, eastValues, tvdValues);
    }

    private static void AppendPointValues(double north, double east, double tvd, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (northValues.Count > 0 &&
            eastValues.Count == northValues.Count &&
            tvdValues.Count == northValues.Count &&
            TryGetLastDouble(northValues, out double lastNorth) &&
            TryGetLastDouble(eastValues, out double lastEast) &&
            TryGetLastDouble(tvdValues, out double lastTvd) &&
            AreClose(lastNorth, north) &&
            AreClose(lastEast, east) &&
            AreClose(lastTvd, tvd))
        {
            return;
        }

        northValues.Add(north);
        eastValues.Add(east);
        tvdValues.Add(tvd);
    }

    private static bool TryGetLastDouble(List<object> values, out double value)
    {
        value = default;
        if (values.Count == 0)
        {
            return false;
        }

        object last = values[^1];
        return last switch
        {
            double d => (value = d) == d,
            float f => (value = f) == f,
            decimal m => (value = (double)m) == (double)m,
            int i => (value = i) == i,
            long l => (value = l) == l,
            _ => false
        };
    }

    private static bool AreClose(double left, double right)
    {
        return Math.Abs(left - right) <= 1e-6;
    }

    private void ClearPlots()
    {
        plotTraces = [];
    }

    private const int MaxDisplayedUncertaintyEllipses = 200;
    private const int EllipsePointCount = 72;

    private FieldModelShared.Trajectory? FindTrajectory(Guid trajectoryId) =>
        trajectoryList.FirstOrDefault(trajectory => trajectory?.MetaInfo?.ID == trajectoryId);

    private string FindTrajectoryName(Guid trajectoryId) =>
        FindTrajectory(trajectoryId)?.Name is { Length: > 0 } name ? name : trajectoryId.ToString();

    private static ClosestApproachResult? CalculateClosestApproach(FieldModelShared.Trajectory first, FieldModelShared.Trajectory second, double? startMd)
    {
        List<TrajectoryPoint> firstPoints = BuildTrajectoryPoints(first);
        List<TrajectoryPoint> secondPoints = BuildTrajectoryPoints(second);
        if (firstPoints.Count < 2 || secondPoints.Count < 2)
        {
            return null;
        }

        ClosestApproachResult? best = null;
        string firstName = string.IsNullOrWhiteSpace(first.Name) ? "trajectory" : first.Name;
        string secondName = string.IsNullOrWhiteSpace(second.Name) ? "trajectory" : second.Name;

        for (int i = 0; i < firstPoints.Count - 1; i++)
        {
            if (!TryClipSegmentAtStartMd(firstPoints[i], firstPoints[i + 1], startMd, out TrajectoryPoint firstStart, out TrajectoryPoint firstEnd))
            {
                continue;
            }

            for (int j = 0; j < secondPoints.Count - 1; j++)
            {
                if (!TryClipSegmentAtStartMd(secondPoints[j], secondPoints[j + 1], startMd, out TrajectoryPoint secondStart, out TrajectoryPoint secondEnd))
                {
                    continue;
                }

                SegmentClosestApproach segmentResult = CalculateSegmentClosestApproach(firstStart, firstEnd, secondStart, secondEnd);
                ClosestApproachPoint firstClosest = InterpolatePoint(firstName, firstStart, firstEnd, segmentResult.FirstParameter);
                ClosestApproachPoint secondClosest = InterpolatePoint(secondName, secondStart, secondEnd, segmentResult.SecondParameter);
                double clearance = CalculateClearance(segmentResult.Distance, firstClosest.BoreholeRadius, secondClosest.BoreholeRadius);
                double? nullableClearance = double.IsNaN(clearance) ? null : clearance;
                ClosestApproachResult candidate = new(firstClosest, secondClosest, segmentResult.Distance, nullableClearance);

                if (best == null || candidate.Distance < best.Distance)
                {
                    best = candidate;
                }
            }
        }

        return best;
    }

    private static bool TryClipSegmentAtStartMd(
        TrajectoryPoint start,
        TrajectoryPoint end,
        double? startMd,
        out TrajectoryPoint clippedStart,
        out TrajectoryPoint clippedEnd)
    {
        clippedStart = start;
        clippedEnd = end;
        if (startMd is not { } minimumMd)
        {
            return true;
        }

        if (start.MD is not { } startMeasuredDepth || end.MD is not { } endMeasuredDepth)
        {
            return false;
        }

        bool startIsIncluded = startMeasuredDepth >= minimumMd;
        bool endIsIncluded = endMeasuredDepth >= minimumMd;
        if (startIsIncluded && endIsIncluded)
        {
            return true;
        }

        if (!startIsIncluded && !endIsIncluded)
        {
            return false;
        }

        double mdDifference = endMeasuredDepth - startMeasuredDepth;
        if (Math.Abs(mdDifference) <= 1e-12)
        {
            return false;
        }

        double intersectionParameter = Clamp01((minimumMd - startMeasuredDepth) / mdDifference);
        TrajectoryPoint intersection = InterpolateTrajectoryPoint(start, end, intersectionParameter);
        if (startIsIncluded)
        {
            clippedEnd = intersection;
        }
        else
        {
            clippedStart = intersection;
        }

        return true;
    }

    private static List<TrajectoryPoint> BuildTrajectoryPoints(FieldModelShared.Trajectory trajectory)
    {
        List<TrajectoryPoint> points = [];
        if (trajectory.SurveyStationList == null)
        {
            return points;
        }

        foreach (FieldModelShared.SurveyStation station in trajectory.SurveyStationList)
        {
            if (station?.X is not { } north || station.Y is not { } east)
            {
                continue;
            }

            double tvd = station.TVD ?? station.Z ?? 0.0;
            TrajectoryPoint point = new(north, east, tvd, station.MD, station.BoreholeRadius);
            if (points.Count == 0 || !points[^1].HasSamePosition(point))
            {
                points.Add(point);
            }
        }

        return points;
    }

    private static SegmentClosestApproach CalculateSegmentClosestApproach(TrajectoryPoint firstStart, TrajectoryPoint firstEnd, TrajectoryPoint secondStart, TrajectoryPoint secondEnd)
    {
        Vector3 p1 = firstStart.Position;
        Vector3 q1 = firstEnd.Position;
        Vector3 p2 = secondStart.Position;
        Vector3 q2 = secondEnd.Position;
        Vector3 d1 = q1 - p1;
        Vector3 d2 = q2 - p2;
        Vector3 r = p1 - p2;
        double a = d1.Dot(d1);
        double e = d2.Dot(d2);
        double f = d2.Dot(r);
        double s;
        double t;

        if (a <= 1e-12 && e <= 1e-12)
        {
            s = 0.0;
            t = 0.0;
        }
        else if (a <= 1e-12)
        {
            s = 0.0;
            t = Clamp01(f / e);
        }
        else
        {
            double c = d1.Dot(r);
            if (e <= 1e-12)
            {
                t = 0.0;
                s = Clamp01(-c / a);
            }
            else
            {
                double b = d1.Dot(d2);
                double denominator = a * e - b * b;
                s = denominator != 0.0 ? Clamp01((b * f - c * e) / denominator) : 0.0;
                t = (b * s + f) / e;

                if (t < 0.0)
                {
                    t = 0.0;
                    s = Clamp01(-c / a);
                }
                else if (t > 1.0)
                {
                    t = 1.0;
                    s = Clamp01((b - c) / a);
                }
            }
        }

        Vector3 closestFirst = p1 + d1 * s;
        Vector3 closestSecond = p2 + d2 * t;
        return new SegmentClosestApproach(s, t, closestFirst.DistanceTo(closestSecond));
    }

    private static ClosestApproachPoint InterpolatePoint(string name, TrajectoryPoint start, TrajectoryPoint end, double parameter)
    {
        TrajectoryPoint point = InterpolateTrajectoryPoint(start, end, parameter);
        return new ClosestApproachPoint(name, point, point.MD, point.BoreholeRadius);
    }

    private static TrajectoryPoint InterpolateTrajectoryPoint(TrajectoryPoint start, TrajectoryPoint end, double parameter)
    {
        Vector3 position = start.Position + (end.Position - start.Position) * parameter;
        double? md = InterpolateNullable(start.MD, end.MD, parameter);
        double? radius = InterpolateNullable(start.BoreholeRadius, end.BoreholeRadius, parameter);
        return new TrajectoryPoint(position.North, position.East, position.Tvd, md, radius);
    }

    private static double? InterpolateNullable(double? start, double? end, double parameter)
    {
        if (start is { } startValue && end is { } endValue)
        {
            return startValue + (endValue - startValue) * parameter;
        }

        return start ?? end;
    }

    private static double CalculateClearance(double centerlineDistance, double? firstRadius, double? secondRadius)
    {
        if (firstRadius is not { } first || secondRadius is not { } second || first < 0.0 || second < 0.0)
        {
            return double.NaN;
        }

        return centerlineDistance - first - second;
    }

    private static double Clamp01(double value) => Math.Min(1.0, Math.Max(0.0, value));

    private static string FormatDistance(double value) => $"{value:0.###} m";

    private static string FormatNullableDistance(double? value) => value.HasValue ? FormatDistance(value.Value) : "N/A";

    private string GetTrajectoryColor(Guid trajectoryId, int colorIndex)
    {
        if (trajectoryColorsById.TryGetValue(trajectoryId, out string? color))
        {
            return color;
        }

        color = GetDefaultTrajectoryColor(colorIndex);
        trajectoryColorsById[trajectoryId] = color;
        return color;
    }

    private void SetTraceColor(PlotTrace trace, string? color)
    {
        if (trace.TrajectoryId is not Guid trajectoryId || trajectoryId == Guid.Empty)
        {
            return;
        }

        string normalizedColor = GetColorPickerValue(color);
        trajectoryColorsById[trajectoryId] = normalizedColor;
        for (int i = 0; i < plotTraces.Count; i++)
        {
            if (plotTraces[i].TrajectoryId == trajectoryId)
            {
                plotTraces[i] = plotTraces[i] with { Color = normalizedColor };
            }
        }
    }

    private static string GetColorPickerValue(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
        {
            return "#000000";
        }

        string trimmed = color.Trim();
        if (IsHexColor(trimmed))
        {
            return trimmed;
        }

        return NamedColorValues.TryGetValue(trimmed, out string? hexColor) ? hexColor : "#000000";
    }

    private static bool IsHexColor(string color)
    {
        if (color.Length != 7 || color[0] != '#')
        {
            return false;
        }

        for (int i = 1; i < color.Length; i++)
        {
            if (!Uri.IsHexDigit(color[i]))
            {
                return false;
            }
        }

        return true;
    }

    private static string GetDefaultTrajectoryColor(int colorIndex)
    {
        if (colorIndex >= 0 && colorIndex < Colors.Length)
        {
            return Colors[colorIndex];
        }

        double hue = (colorIndex * 137.508) % 360.0;
        return HslToHex(hue, 0.64, 0.42);
    }

    private static string HslToHex(double hue, double saturation, double lightness)
    {
        hue = ((hue % 360.0) + 360.0) % 360.0;
        saturation = Clamp01(saturation);
        lightness = Clamp01(lightness);

        double chroma = (1.0 - Math.Abs(2.0 * lightness - 1.0)) * saturation;
        double huePrime = hue / 60.0;
        double x = chroma * (1.0 - Math.Abs(huePrime % 2.0 - 1.0));
        double red1 = 0.0;
        double green1 = 0.0;
        double blue1 = 0.0;

        if (huePrime < 1.0)
        {
            red1 = chroma;
            green1 = x;
        }
        else if (huePrime < 2.0)
        {
            red1 = x;
            green1 = chroma;
        }
        else if (huePrime < 3.0)
        {
            green1 = chroma;
            blue1 = x;
        }
        else if (huePrime < 4.0)
        {
            green1 = x;
            blue1 = chroma;
        }
        else if (huePrime < 5.0)
        {
            red1 = x;
            blue1 = chroma;
        }
        else
        {
            red1 = chroma;
            blue1 = x;
        }

        double match = lightness - chroma / 2.0;
        int red = (int)Math.Round((red1 + match) * 255.0);
        int green = (int)Math.Round((green1 + match) * 255.0);
        int blue = (int)Math.Round((blue1 + match) * 255.0);
        return $"#{red:X2}{green:X2}{blue:X2}";
    }

