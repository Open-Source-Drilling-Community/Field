@page "/FieldTrajectories"
@inject ILogger<FieldTrajectories> logger
@inject ISnackbar Snackbar
@inject IFieldAPIUtils Api
@using FieldModelShared = NORCE.Drilling.Field.ModelShared

<MudUnitAndReferenceChoiceTag HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.SeaWaterLevelDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@DataUtils.UpdatePositionReferenceName"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource"
                              LeaseLinePositionReferenceSource="@DataUtils.LeaseLinePositionReferenceSource"
                              >
    @if (fieldList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <MudStack Spacing="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h5">Field Trajectories</MudText>
                        <MudText Typo="Typo.body2">All wellbore trajectories for the selected field, shown in 3D and as a horizontal projection.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="8" md="4">
                        <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                            @foreach (FieldModelShared.Field field in AvailableFields)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="ReloadSelectedFieldAsync" Disabled="@(selectedFieldId == null)">Reload</MudButton>
                    </MudItem>
                </MudGrid>

            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@errorMessage</MudAlert>
            }
            else if (isLoadingTrajectories)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Loading trajectories for the selected field.</MudAlert>
            }
            else if (selectedFieldId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a field to display its wellbore trajectories.</MudAlert>
            }
            else if (trajectoryList.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No trajectories were found for the selected field.</MudAlert>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">3D View</MudText>
                            <Scatter3DPlot XUnit="PositionDrilling"
                                           YUnit="PositionDrilling"
                                           ZUnit="DepthDrilling"
                                           NameList="@PlotNames"
                                           ModeFlagList="@PlotModeFlags"
                                           ColorList="@PlotColors"
                                           MarkerSizeList="@PlotMarkerSizes"
                                           XValuesList="@EastValuesList"
                                           YValuesList="@NorthValuesList"
                                           ZValuesList="@TvdValuesList"
                                           XAxisTitle="Easting"
                                           YAxisTitle="Northing"
                                           ZAxisTitle="TVD"
                                           PlotTitle="Field trajectories"
                                           PlotHeight="600"
                                           ZAxisReversed="true"
                                           XAxisUsesPositionReference="true"
                                           YAxisUsesPositionReference="true"
                                           ZAxisUsesDepthReference="true"
                                           XAxisPositionDirection="@PositionDirectionType.East"
                                           YAxisPositionDirection="@PositionDirectionType.North"
                                           TraceClicked="OnTrajectoryTraceClicked" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">Horizontal Projection</MudText>
                            <ScatterPlot XUnit="PositionDrilling"
                                         YUnit="PositionDrilling"
                                         NameList="@PlotNames"
                                         ModeFlagList="@PlotModeFlags"
                                         ColorList="@PlotColors"
                                         XValuesList="@EastValuesList"
                                         YValuesList="@NorthValuesList"
                                         XAxisTitle="Easting"
                                         YAxisTitle="Northing"
                                         PlotTitle="Horizontal projection"
                                         PlotHeight="600"
                                         AspectRatio="1"
                                         XAxisUsesPositionReference="true"
                                         YAxisUsesPositionReference="true"
                                         XAxisPositionDirection="@PositionDirectionType.East"
                                         YAxisPositionDirection="@PositionDirectionType.North" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.h6">Closest Approach</MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ClearClosestApproachSelection" Disabled="@(selectedTrajectoryIds.Count == 0 && closestApproachResult == null)">Clear</MudButton>
                        </MudStack>
                        <MudText Typo="Typo.body2">Click two trajectories in the 3D view to calculate the closest centerline approach.</MudText>
                        @if (selectedTrajectoryIds.Count > 0)
                        {
                            <MudText Typo="Typo.body2">Selected: @SelectedTrajectoryText</MudText>
                        }
                        @if (closestApproachResult != null)
                        {
                            <MudGrid>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">Centerline distance</MudText>
                                    <MudText Typo="Typo.body2">@FormatDistance(closestApproachResult.Distance)</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">Borehole clearance</MudText>
                                    <MudText Typo="Typo.body2">@FormatNullableDistance(closestApproachResult.Clearance)</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">@closestApproachResult.First.Name</MudText>
                                    <MudText Typo="Typo.body2">MD @FormatNullableDistance(closestApproachResult.First.MD), radius @FormatNullableDistance(closestApproachResult.First.BoreholeRadius)</MudText>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <MudText Typo="Typo.subtitle2">@closestApproachResult.Second.Name</MudText>
                                    <MudText Typo="Typo.body2">MD @FormatNullableDistance(closestApproachResult.Second.MD), radius @FormatNullableDistance(closestApproachResult.Second.BoreholeRadius)</MudText>
                                </MudItem>
                            </MudGrid>
                        }
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Legend</MudText>
                    <MudGrid>
                        @foreach (var trace in plotTraces)
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span style="@($"width:18px;height:18px;border-radius:50%;display:inline-block;background:{trace.Color};")"></span>
                                    <MudText Typo="Typo.body2">@trace.Name</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        </MudStack>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    private List<FieldModelShared.Field>? fieldList;
    private List<FieldModelShared.TrajectoryLight> trajectoryLightList = [];
    private List<FieldModelShared.Trajectory> trajectoryList = [];
    private Guid? selectedFieldId;
    private string? errorMessage;
    private bool isLoadingTrajectories;

    private List<PlotTrace> plotTraces = [];
    private List<Guid> selectedTrajectoryIds = [];
    private ClosestApproachResult? closestApproachResult;

    private List<string> PlotNames => plotTraces.Select(trace => trace.Name).ToList();
    private List<int> PlotModeFlags => plotTraces.Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotColors => plotTraces.Select(trace => trace.Color).ToList();
    private List<double?> PlotMarkerSizes => plotTraces.Select(trace => trace.MarkerSize).ToList();
    private List<List<object>> NorthValuesList => plotTraces.Select(trace => trace.NorthValues).ToList();
    private List<List<object>> EastValuesList => plotTraces.Select(trace => trace.EastValues).ToList();
    private List<List<object>> TvdValuesList => plotTraces.Select(trace => trace.TvdValues).ToList();
    private string SelectedTrajectoryText => string.Join(" -> ", selectedTrajectoryIds.Select(id => FindTrajectoryName(id)));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            logger.LogInformation("Trying to load list of Fields from client: {Host}", Api.HostNameField);
            fieldList = (await Api.ClientField.GetAllFieldAsync()).OrderBy(field => field.Name).ToList();
            selectedFieldId = null;
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading fields");
            errorMessage = "Unable to load fields.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading fields");
            errorMessage = "Unable to load fields.";
            Snackbar.Add(errorMessage, Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private List<FieldModelShared.Field> AvailableFields =>
        fieldList?
            .Where(field => field?.MetaInfo != null)
            .OrderBy(field => field.Name)
            .ToList() ?? [];

    private async Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId = fieldId;
        if (selectedFieldId is Guid selected)
        {
            await LoadTrajectoriesAsync(selected);
        }
        else
        {
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
            errorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadSelectedFieldAsync()
    {
        if (selectedFieldId is Guid fieldId)
        {
            await LoadTrajectoriesAsync(fieldId);
        }
    }

    private async Task LoadTrajectoriesAsync(Guid fieldId)
    {
        try
        {
            errorMessage = null;
            isLoadingTrajectories = true;
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
            await InvokeAsync(StateHasChanged);
            logger.LogInformation("Loading trajectory light data for field {FieldId}", fieldId);
            trajectoryLightList = (await Api.ClientTrajectory.GetAllTrajectoryLightAsync(fieldId: fieldId)).OrderBy(trajectory => trajectory.Name).ToList();

            List<Task<FieldModelShared.Trajectory>> detailTasks = trajectoryLightList
                .Where(light => light?.MetaInfo != null && light.MetaInfo.ID != Guid.Empty)
                .Select(light => Api.ClientTrajectory.GetTrajectoryByIdAsync(light.MetaInfo.ID))
                .ToList();

            trajectoryList = (await Task.WhenAll(detailTasks))
                .Where(trajectory => trajectory != null)
                .OrderBy(trajectory => trajectory.Name)
                .ToList();

            UpdatePlots();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading trajectories for field {FieldId}", fieldId);
            errorMessage = "Unable to load trajectories for the selected field.";
            Snackbar.Add(errorMessage, Severity.Error);
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading trajectories for field {FieldId}", fieldId);
            errorMessage = "Unable to load trajectories for the selected field.";
            Snackbar.Add(errorMessage, Severity.Error);
            trajectoryLightList.Clear();
            trajectoryList.Clear();
            ClearClosestApproachSelection();
            ClearPlots();
        }
        finally
        {
            isLoadingTrajectories = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void UpdatePlots()
    {
        ClearPlots();
        int colorIndex = 0;
        List<PlotTrace> nextPlotTraces = [];

        foreach (FieldModelShared.Trajectory trajectory in trajectoryList)
        {
            if (trajectory?.SurveyStationList == null || trajectory.SurveyStationList.Count == 0)
            {
                continue;
            }

            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];

            foreach (FieldModelShared.SurveyStation station in trajectory.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }

            if (northValues.Count < 2 || northValues.Count != eastValues.Count || northValues.Count != tvdValues.Count)
            {
                continue;
            }

            nextPlotTraces.Add(new PlotTrace(
                string.IsNullOrWhiteSpace(trajectory.Name) ? "trajectory" : trajectory.Name,
                3,
                Colors[colorIndex % Colors.Length],
                2.0,
                trajectory.MetaInfo.ID,
                true,
                northValues,
                eastValues,
                tvdValues));
            colorIndex++;
        }

        AppendClosestApproachOverlay(nextPlotTraces);
        plotTraces = nextPlotTraces;
    }

    private async Task OnTrajectoryTraceClicked(int traceIndex)
    {
        if (traceIndex < 0 || traceIndex >= plotTraces.Count)
        {
            return;
        }

        PlotTrace trace = plotTraces[traceIndex];
        if (!trace.IsSelectable || trace.TrajectoryId is not { } trajectoryId)
        {
            return;
        }

        if (selectedTrajectoryIds.Count == 1 && selectedTrajectoryIds[0] == trajectoryId)
        {
            Snackbar.Add("Select a different trajectory for closest approach.", Severity.Info);
            return;
        }

        if (selectedTrajectoryIds.Count >= 2)
        {
            selectedTrajectoryIds.Clear();
            closestApproachResult = null;
        }

        selectedTrajectoryIds.Add(trajectoryId);

        if (selectedTrajectoryIds.Count == 2)
        {
            FieldModelShared.Trajectory? first = FindTrajectory(selectedTrajectoryIds[0]);
            FieldModelShared.Trajectory? second = FindTrajectory(selectedTrajectoryIds[1]);
            closestApproachResult = first != null && second != null
                ? CalculateClosestApproach(first, second)
                : null;

            if (closestApproachResult == null)
            {
                Snackbar.Add("Unable to calculate closest approach for the selected trajectories.", Severity.Warning);
            }
        }

        UpdatePlots();
        await InvokeAsync(StateHasChanged);
    }

    private void ClearClosestApproachSelection()
    {
        selectedTrajectoryIds.Clear();
        closestApproachResult = null;
        UpdatePlots();
    }

    private void AppendClosestApproachOverlay(List<PlotTrace> traces)
    {
        if (closestApproachResult == null)
        {
            return;
        }

        traces.Add(new PlotTrace(
            "Closest approach",
            1,
            "#d62728",
            null,
            null,
            false,
            [closestApproachResult.First.Point.North, closestApproachResult.Second.Point.North],
            [closestApproachResult.First.Point.East, closestApproachResult.Second.Point.East],
            [closestApproachResult.First.Point.Tvd, closestApproachResult.Second.Point.Tvd]));

        traces.Add(new PlotTrace(
            "Closest points",
            2,
            "#d62728",
            5.0,
            null,
            false,
            [closestApproachResult.First.Point.North, closestApproachResult.Second.Point.North],
            [closestApproachResult.First.Point.East, closestApproachResult.Second.Point.East],
            [closestApproachResult.First.Point.Tvd, closestApproachResult.Second.Point.Tvd]));
    }

    private void AppendPoint(FieldModelShared.SurveyStation? point, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (point?.X is not { } north || point.Y is not { } east)
        {
            return;
        }

        double tvd = point.TVD ?? point.Z ?? 0.0;
        AppendPointValues(north, east, tvd, northValues, eastValues, tvdValues);
    }

    private static void AppendPointValues(double north, double east, double tvd, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (northValues.Count > 0 &&
            eastValues.Count == northValues.Count &&
            tvdValues.Count == northValues.Count &&
            TryGetLastDouble(northValues, out double lastNorth) &&
            TryGetLastDouble(eastValues, out double lastEast) &&
            TryGetLastDouble(tvdValues, out double lastTvd) &&
            AreClose(lastNorth, north) &&
            AreClose(lastEast, east) &&
            AreClose(lastTvd, tvd))
        {
            return;
        }

        northValues.Add(north);
        eastValues.Add(east);
        tvdValues.Add(tvd);
    }

    private static bool TryGetLastDouble(List<object> values, out double value)
    {
        value = default;
        if (values.Count == 0)
        {
            return false;
        }

        object last = values[^1];
        return last switch
        {
            double d => (value = d) == d,
            float f => (value = f) == f,
            decimal m => (value = (double)m) == (double)m,
            int i => (value = i) == i,
            long l => (value = l) == l,
            _ => false
        };
    }

    private static bool AreClose(double left, double right)
    {
        return Math.Abs(left - right) <= 1e-6;
    }

    private void ClearPlots()
    {
        plotTraces = [];
    }

    private FieldModelShared.Trajectory? FindTrajectory(Guid trajectoryId) =>
        trajectoryList.FirstOrDefault(trajectory => trajectory?.MetaInfo?.ID == trajectoryId);

    private string FindTrajectoryName(Guid trajectoryId) =>
        FindTrajectory(trajectoryId)?.Name is { Length: > 0 } name ? name : trajectoryId.ToString();

    private static ClosestApproachResult? CalculateClosestApproach(FieldModelShared.Trajectory first, FieldModelShared.Trajectory second)
    {
        List<TrajectoryPoint> firstPoints = BuildTrajectoryPoints(first);
        List<TrajectoryPoint> secondPoints = BuildTrajectoryPoints(second);
        if (firstPoints.Count < 2 || secondPoints.Count < 2)
        {
            return null;
        }

        ClosestApproachResult? best = null;
        string firstName = string.IsNullOrWhiteSpace(first.Name) ? "trajectory" : first.Name;
        string secondName = string.IsNullOrWhiteSpace(second.Name) ? "trajectory" : second.Name;

        for (int i = 0; i < firstPoints.Count - 1; i++)
        {
            for (int j = 0; j < secondPoints.Count - 1; j++)
            {
                SegmentClosestApproach segmentResult = CalculateSegmentClosestApproach(firstPoints[i], firstPoints[i + 1], secondPoints[j], secondPoints[j + 1]);
                ClosestApproachPoint firstClosest = InterpolatePoint(firstName, firstPoints[i], firstPoints[i + 1], segmentResult.FirstParameter);
                ClosestApproachPoint secondClosest = InterpolatePoint(secondName, secondPoints[j], secondPoints[j + 1], segmentResult.SecondParameter);
                double clearance = CalculateClearance(segmentResult.Distance, firstClosest.BoreholeRadius, secondClosest.BoreholeRadius);
                double? nullableClearance = double.IsNaN(clearance) ? null : clearance;
                ClosestApproachResult candidate = new(firstClosest, secondClosest, segmentResult.Distance, nullableClearance);

                if (best == null || candidate.Distance < best.Distance)
                {
                    best = candidate;
                }
            }
        }

        return best;
    }

    private static List<TrajectoryPoint> BuildTrajectoryPoints(FieldModelShared.Trajectory trajectory)
    {
        List<TrajectoryPoint> points = [];
        if (trajectory.SurveyStationList == null)
        {
            return points;
        }

        foreach (FieldModelShared.SurveyStation station in trajectory.SurveyStationList)
        {
            if (station?.X is not { } north || station.Y is not { } east)
            {
                continue;
            }

            double tvd = station.TVD ?? station.Z ?? 0.0;
            TrajectoryPoint point = new(north, east, tvd, station.MD, station.BoreholeRadius);
            if (points.Count == 0 || !points[^1].HasSamePosition(point))
            {
                points.Add(point);
            }
        }

        return points;
    }

    private static SegmentClosestApproach CalculateSegmentClosestApproach(TrajectoryPoint firstStart, TrajectoryPoint firstEnd, TrajectoryPoint secondStart, TrajectoryPoint secondEnd)
    {
        Vector3 p1 = firstStart.Position;
        Vector3 q1 = firstEnd.Position;
        Vector3 p2 = secondStart.Position;
        Vector3 q2 = secondEnd.Position;
        Vector3 d1 = q1 - p1;
        Vector3 d2 = q2 - p2;
        Vector3 r = p1 - p2;
        double a = d1.Dot(d1);
        double e = d2.Dot(d2);
        double f = d2.Dot(r);
        double s;
        double t;

        if (a <= 1e-12 && e <= 1e-12)
        {
            s = 0.0;
            t = 0.0;
        }
        else if (a <= 1e-12)
        {
            s = 0.0;
            t = Clamp01(f / e);
        }
        else
        {
            double c = d1.Dot(r);
            if (e <= 1e-12)
            {
                t = 0.0;
                s = Clamp01(-c / a);
            }
            else
            {
                double b = d1.Dot(d2);
                double denominator = a * e - b * b;
                s = denominator != 0.0 ? Clamp01((b * f - c * e) / denominator) : 0.0;
                t = (b * s + f) / e;

                if (t < 0.0)
                {
                    t = 0.0;
                    s = Clamp01(-c / a);
                }
                else if (t > 1.0)
                {
                    t = 1.0;
                    s = Clamp01((b - c) / a);
                }
            }
        }

        Vector3 closestFirst = p1 + d1 * s;
        Vector3 closestSecond = p2 + d2 * t;
        return new SegmentClosestApproach(s, t, closestFirst.DistanceTo(closestSecond));
    }

    private static ClosestApproachPoint InterpolatePoint(string name, TrajectoryPoint start, TrajectoryPoint end, double parameter)
    {
        Vector3 position = start.Position + (end.Position - start.Position) * parameter;
        double? md = InterpolateNullable(start.MD, end.MD, parameter);
        double? radius = InterpolateNullable(start.BoreholeRadius, end.BoreholeRadius, parameter);
        return new ClosestApproachPoint(name, new TrajectoryPoint(position.North, position.East, position.Tvd, md, radius), md, radius);
    }

    private static double? InterpolateNullable(double? start, double? end, double parameter)
    {
        if (start is { } startValue && end is { } endValue)
        {
            return startValue + (endValue - startValue) * parameter;
        }

        return start ?? end;
    }

    private static double CalculateClearance(double centerlineDistance, double? firstRadius, double? secondRadius)
    {
        if (firstRadius is not { } first || secondRadius is not { } second || first < 0.0 || second < 0.0)
        {
            return double.NaN;
        }

        return centerlineDistance - first - second;
    }

    private static double Clamp01(double value) => Math.Min(1.0, Math.Max(0.0, value));

    private static string FormatDistance(double value) => $"{value:0.###} m";

    private static string FormatNullableDistance(double? value) => value.HasValue ? FormatDistance(value.Value) : "N/A";

    private static readonly string[] Colors =
    [
        "black",
        "blue",
        "grey",
        "red",
        "orange",
        "green",
        "yellow",
        "pink",
        "brown",
        "purple"
    ];

    private sealed record PlotTrace(
        string Name,
        int ModeFlag,
        string Color,
        double? MarkerSize,
        Guid? TrajectoryId,
        bool IsSelectable,
        List<object> NorthValues,
        List<object> EastValues,
        List<object> TvdValues);

    private readonly record struct Vector3(double North, double East, double Tvd)
    {
        public static Vector3 operator +(Vector3 left, Vector3 right) => new(left.North + right.North, left.East + right.East, left.Tvd + right.Tvd);
        public static Vector3 operator -(Vector3 left, Vector3 right) => new(left.North - right.North, left.East - right.East, left.Tvd - right.Tvd);
        public static Vector3 operator *(Vector3 value, double factor) => new(value.North * factor, value.East * factor, value.Tvd * factor);
        public double Dot(Vector3 other) => North * other.North + East * other.East + Tvd * other.Tvd;
        public double DistanceTo(Vector3 other) => Math.Sqrt(Math.Pow(North - other.North, 2.0) + Math.Pow(East - other.East, 2.0) + Math.Pow(Tvd - other.Tvd, 2.0));
    }

    private sealed record TrajectoryPoint(double North, double East, double Tvd, double? MD, double? BoreholeRadius)
    {
        public Vector3 Position => new(North, East, Tvd);
        public bool HasSamePosition(TrajectoryPoint other) => AreClose(North, other.North) && AreClose(East, other.East) && AreClose(Tvd, other.Tvd);
    }

    private sealed record SegmentClosestApproach(double FirstParameter, double SecondParameter, double Distance);

    private sealed record ClosestApproachPoint(string Name, TrajectoryPoint Point, double? MD, double? BoreholeRadius);

    private sealed record ClosestApproachResult(ClosestApproachPoint First, ClosestApproachPoint Second, double Distance, double? Clearance);
}
