    private void SelectMembershipOption(FieldMembershipCategory category, FieldMembershipOption option)
    {
        if (category.MetaInfo?.ID is not Guid categoryId || categoryId == Guid.Empty || option.ID == Guid.Empty)
        {
            return;
        }

        _selectedMembershipCategoryId = categoryId;
        _selectedMembershipOptionId = option.ID;
    }

    private bool CanAssignSelectedMembershipOption()
    {
        if (_selectedMembershipCategoryId is not Guid categoryId || _selectedMembershipOptionId is not Guid optionId)
        {
            return false;
        }

        FieldMembershipCategory? category = FindMembershipCategory(categoryId);
        if (category == null || !MembershipCategoryContainsOption(category, optionId))
        {
            return false;
        }

        return !IsMembershipOptionUnavailable(category);
    }

    private void AssignSelectedMembershipOption()
    {
        if (!CanAssignSelectedMembershipOption())
        {
            return;
        }

        _fieldMembershipAssignments.Add(new FieldMembershipAssignment
        {
            ID = Guid.NewGuid(),
            MembershipCategoryID = _selectedMembershipCategoryId,
            MembershipOptionID = _selectedMembershipOptionId
        });
    }

    private void UnassignSelectedMembership()
    {
        if (_selectedMembershipAssignmentId is not Guid assignmentId)
        {
            return;
        }

        FieldMembershipAssignment? assignment = _fieldMembershipAssignments.FirstOrDefault(item => item.ID == assignmentId);
        if (assignment != null)
        {
            _fieldMembershipAssignments.Remove(assignment);
        }
        _selectedMembershipAssignment = null;
        _selectedMembershipAssignmentId = null;
    }

    private void SetSelectedMembershipAssignment(FieldMembershipAssignment? assignment)
    {
        _selectedMembershipAssignment = assignment;
        _selectedMembershipAssignmentId = assignment?.ID;
    }

    private string GetMembershipAssignmentDisplayName(FieldMembershipAssignment assignment)
    {
        FieldMembershipCategory? category = assignment.MembershipCategoryID is Guid categoryId ? FindMembershipCategory(categoryId) : null;
        FieldMembershipOption? option = assignment.MembershipOptionID is Guid optionId ? FindMembershipOption(category, optionId) : null;
        return $"{category?.Name ?? "Unknown category"}: {option?.Name ?? "Unknown option"}";
    }

    private bool MembershipCategoryHasValidityPeriod(FieldMembershipAssignment assignment)
    {
        return assignment.MembershipCategoryID is Guid categoryId && FindMembershipCategory(categoryId)?.HasValidityPeriod == true;
    }

    private void SetMembershipAssignmentFromDate(FieldMembershipAssignment assignment, DateTime? value)
    {
        assignment.FromDate = ToDateTimeOffset(value);
    }

    private void SetMembershipAssignmentToDate(FieldMembershipAssignment assignment, DateTime? value)
    {
        assignment.ToDate = ToDateTimeOffset(value);
    }

    private FieldMembershipCategory? FindMembershipCategory(Guid categoryId)
    {
        return _fieldMembershipCategories.FirstOrDefault(category => category.MetaInfo?.ID == categoryId);
    }

    private static FieldMembershipOption? FindMembershipOption(FieldMembershipCategory? category, Guid optionId)
    {
        return category?.Options?.FirstOrDefault(option => option.ID == optionId);
    }

    private static bool MembershipCategoryContainsOption(FieldMembershipCategory category, Guid optionId)
    {
        return category.Options?.Any(option => option.ID == optionId) == true;
    }

    private bool TryValidateMembershipAssignments()
    {
        foreach (FieldMembershipAssignment assignment in _fieldMembershipAssignments)
        {
            if (assignment.MembershipCategoryID is not Guid categoryId || assignment.MembershipOptionID is not Guid optionId)
            {
                Snackbar.Add("Membership assignments must have a category and an option", Severity.Warning);
                return false;
            }

            FieldMembershipCategory? category = FindMembershipCategory(categoryId);
            if (category == null || !MembershipCategoryContainsOption(category, optionId))
            {
                Snackbar.Add("Membership assignments must reference existing categories and options", Severity.Warning);
                return false;
            }

            if (!category.HasValidityPeriod)
            {
                assignment.FromDate = null;
                assignment.ToDate = null;
            }

            if (assignment.FromDate != null && assignment.ToDate != null && assignment.FromDate > assignment.ToDate)
            {
                Snackbar.Add("Membership assignment From date cannot be after To date", Severity.Warning);
                return false;
            }
        }

        foreach (FieldMembershipCategory category in _fieldMembershipCategories.Where(category => category.IsExclusive))
        {
            if (category.MetaInfo?.ID is not Guid categoryId)
            {
                continue;
            }

            List<FieldMembershipAssignment> categoryAssignments = _fieldMembershipAssignments
                .Where(assignment => assignment.MembershipCategoryID == categoryId)
                .ToList();

            if (!category.HasValidityPeriod && categoryAssignments.Count > 1)
            {
                Snackbar.Add($"Only one membership option can be assigned for '{category.Name}'", Severity.Warning);
                return false;
            }

            if (category.HasValidityPeriod && HasOverlappingMembershipAssignments(categoryAssignments))
            {
                Snackbar.Add($"Membership assignment periods cannot overlap for '{category.Name}'", Severity.Warning);
                return false;
            }
        }

        return true;
    }

    private static bool HasOverlappingMembershipAssignments(List<FieldMembershipAssignment> assignments)
    {
        for (int i = 0; i < assignments.Count; i++)
        {
            for (int j = i + 1; j < assignments.Count; j++)
            {
                if (MembershipIntervalsOverlap(assignments[i], assignments[j]))
                {
                    return true;
                }
            }
        }

        return false;
    }

    private static bool MembershipIntervalsOverlap(FieldMembershipAssignment first, FieldMembershipAssignment second)
    {
        DateTimeOffset firstStart = first.FromDate ?? DateTimeOffset.MinValue;
        DateTimeOffset firstEnd = first.ToDate ?? DateTimeOffset.MaxValue;
        DateTimeOffset secondStart = second.FromDate ?? DateTimeOffset.MinValue;
        DateTimeOffset secondEnd = second.ToDate ?? DateTimeOffset.MaxValue;
        return firstStart <= secondEnd && secondStart <= firstEnd;
    }

    private CartographicProjectionLight? FindCartographicProjection(Guid? cartographicProjectionID)
    {
        if (cartographicProjectionID == null || cartographicProjectionID == Guid.Empty || CartographicProjections == null)
        {
            return null;
        }

        return CartographicProjections.FirstOrDefault(projection => projection.MetaInfo?.ID == cartographicProjectionID);
    }

