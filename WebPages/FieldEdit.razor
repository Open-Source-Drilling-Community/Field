    private async Task RefreshCartographicGridPositionReferenceAsync()
    {
        if (isRefreshingCartographicGridReference_)
        {
            hasPendingCartographicGridReferenceRefresh_ = true;
            return;
        }

        try
        {
            isRefreshingCartographicGridReference_ = true;
            if (CurrentField?.MetaInfo?.ID is not Guid fieldId || fieldId == Guid.Empty)
            {
                ClearCartographicReferences();
                ClearMeanSeaLevelDepthReference();
                return;
            }

            ReferencePositionSample? sample = await ResolveCartographicReferenceSampleAsync(fieldId);
            if (sample == null)
            {
                ClearCartographicReferences();
                ClearMeanSeaLevelDepthReference();
                return;
            }

            await RefreshMeanSeaLevelDepthReferenceAsync(sample.Value);

            CartographicCoordinate? cartographicCoordinate = await ConvertReferenceSampleToCartographicAsync(fieldId, sample.Value);
            if (cartographicCoordinate?.Northing == null || cartographicCoordinate.Easting == null)
            {
                ClearCartographicReferences();
                return;
            }

            DataUtils.CartographicGridPositionReferenceSource.CartographicGridNorthPositionReference =
                cartographicCoordinate.Northing.Value - sample.Value.RiemannianNorth;
            DataUtils.CartographicGridPositionReferenceSource.CartographicGridEastPositionReference =
                cartographicCoordinate.Easting.Value - sample.Value.RiemannianEast;
            DataUtils.CartographicProjectionDatumGeodeticReferenceSource.CartographicProjectionDatumLatitudeReference =
                cartographicCoordinate.GeodeticCoordinate?.LatitudeDatum == null
                    ? null
                    : cartographicCoordinate.GeodeticCoordinate.LatitudeDatum.Value - sample.Value.Latitude;
            DataUtils.CartographicProjectionDatumGeodeticReferenceSource.CartographicProjectionDatumLongitudeReference =
                cartographicCoordinate.GeodeticCoordinate?.LongitudeDatum == null
                    ? null
                    : cartographicCoordinate.GeodeticCoordinate.LongitudeDatum.Value - sample.Value.Longitude;
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Unable to update the cartographic grid position reference for the field");
            ClearCartographicReferences();
        }
        finally
        {
            isRefreshingCartographicGridReference_ = false;
            await InvokeAsync(StateHasChanged);
            if (hasPendingCartographicGridReferenceRefresh_)
            {
                hasPendingCartographicGridReferenceRefresh_ = false;
                _ = RefreshCartographicGridPositionReferenceAsync();
            }
        }
    }

    private async Task RefreshMeanSeaLevelDepthReferenceAsync(ReferencePositionSample sample)
    {
        try
        {
            DataUtils.MeanSeaLevelDepthReferenceSource.MeanSeaLevelDepthReference =
                await FieldReferenceDatumUtils.CalculateMeanSeaLevelDepthReferenceAsync(Api, sample.Latitude, sample.Longitude);
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Unable to update the mean sea level depth reference for the field");
            ClearMeanSeaLevelDepthReference();
        }
    }

    private async Task<ReferencePositionSample?> ResolveCartographicReferenceSampleAsync(Guid fieldId)
    {
        ReferencePositionSample? explicitReference = TryBuildReferenceSample(
            _referencePoint.RiemannianNorth,
            _referencePoint.RiemannianEast,
            _referencePoint.Latitude,
            _referencePoint.Longitude);
        if (explicitReference != null)
        {
            return explicitReference;
        }

        ReferencePositionSample? delineationReference = TryBuildDelineationBarycenterSample();
        if (delineationReference != null)
        {
            return delineationReference;
        }

        ReferencePositionSample? clusterReference = await TryBuildClusterBarycenterSampleAsync(fieldId);
        if (clusterReference != null)
        {
            return clusterReference;
        }

        return await TryBuildTrajectoryBarycenterSampleAsync(fieldId);
    }

    private ReferencePositionSample? TryBuildDelineationBarycenterSample()
    {
        IEnumerable<DtoPoint3DGlobalCoordinates> points = _delineationLines
            .SelectMany(line => line.Points ?? []);

        return TryBuildBarycenterSample(points.Select(point => (
            North: point.RiemannianNorth ?? point.X,
            East: point.RiemannianEast ?? point.Y,
            Latitude: point.Latitude,
            Longitude: point.Longitude)));
    }

    private async Task<ReferencePositionSample?> TryBuildTrajectoryBarycenterSampleAsync(Guid fieldId)
    {
        ICollection<TrajectoryLight> trajectoryLights = await Api.ClientTrajectory.GetAllTrajectoryLightAsync(fieldId: fieldId);
        List<Guid> trajectoryIds = trajectoryLights
            .Where(trajectory => trajectory?.MetaInfo?.ID != null && trajectory.MetaInfo.ID != Guid.Empty)
            .Take(20)
            .Select(trajectory => trajectory.MetaInfo.ID)
            .ToList();

        List<(double? North, double? East, double? Latitude, double? Longitude)> samples = [];
        foreach (Guid trajectoryId in trajectoryIds)
        {
            samples.AddRange(await LoadTrajectoryPositionSamplesAsync(trajectoryId));
        }

        return TryBuildBarycenterSample(samples);
    }

    private async Task<ReferencePositionSample?> TryBuildClusterBarycenterSampleAsync(Guid fieldId)
    {
        ICollection<Cluster> clusters = await Api.ClientCluster.GetAllClusterAsync();
        List<(double? North, double? East, double? Latitude, double? Longitude)> clusterSamples = clusters
            .Where(cluster => cluster?.FieldID == fieldId)
            .Select(TryBuildClusterReferenceSample)
            .Where(sample => sample != null)
            .Select(sample => (
                North: (double?)sample!.Value.RiemannianNorth,
                East: (double?)sample.Value.RiemannianEast,
                Latitude: (double?)sample.Value.Latitude,
                Longitude: (double?)sample.Value.Longitude))
            .ToList();

        return TryBuildBarycenterSample(clusterSamples);
    }

    private static ReferencePositionSample? TryBuildClusterReferenceSample(Cluster cluster)
    {
        ReferencePositionSample? referenceSample = TryBuildReferenceSample(
            null,
            null,
            cluster.ReferenceLatitude?.GaussianValue?.Mean,
            cluster.ReferenceLongitude?.GaussianValue?.Mean);
        if (referenceSample != null)
        {
            return referenceSample;
        }

        IEnumerable<Slot> slots = cluster.Slots?.Values ?? [];
        return TryBuildBarycenterSample(slots.Select(slot => (
            North: (double?)null,
            East: (double?)null,
            Latitude: slot.Latitude?.GaussianValue?.Mean,
            Longitude: slot.Longitude?.GaussianValue?.Mean)));
    }

    private async Task<List<(double? North, double? East, double? Latitude, double? Longitude)>> LoadTrajectoryPositionSamplesAsync(Guid trajectoryId)
    {
        List<(double? North, double? East, double? Latitude, double? Longitude)> samples = [];
        int chunkCount = await Api.HttpClientTrajectory.GetFromJsonAsync<int>($"Trajectory/{trajectoryId}/SurveyStations/ChunkCount");
        for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
        {
            SurveyStationChunk? chunk = await Api.HttpClientTrajectory.GetFromJsonAsync<SurveyStationChunk>($"Trajectory/{trajectoryId}/SurveyStations/Chunks/{chunkIndex}");
            if (chunk?.SurveyStationList == null)
            {
                continue;
            }

            samples.AddRange(chunk.SurveyStationList.Select(station => (
                North: station.RiemannianNorth ?? station.X,
                East: station.RiemannianEast ?? station.Y,
                Latitude: station.Latitude,
                Longitude: station.Longitude)));
        }

        return samples;
    }

    private static ReferencePositionSample? TryBuildBarycenterSample(IEnumerable<(double? North, double? East, double? Latitude, double? Longitude)> points)
    {
        List<(double North, double East)> northEastPoints = points
            .Where(point => point.North != null && point.East != null)
            .Select(point => (point.North!.Value, point.East!.Value))
            .ToList();

        if (northEastPoints.Count == 0)
        {
            return null;
        }

        double north = northEastPoints.Average(point => point.North);
        double east = northEastPoints.Average(point => point.East);
        return TryBuildReferenceSample(north, east, null, null);
    }

    private static ReferencePositionSample? TryBuildReferenceSample(double? north, double? east, double? latitude, double? longitude)
    {
        DtoPoint3DGlobalCoordinates point = new()
        {
            RiemannianNorth = north,
            RiemannianEast = east,
            Latitude = latitude,
            Longitude = longitude,
            TVD = 0,
            Z = 0
        };

        if ((point.Latitude == null || point.Longitude == null) && point.RiemannianNorth != null && point.RiemannianEast != null)
        {
            SetLatitudeLongitudeFromNorthEast(point);
        }
        else if ((point.RiemannianNorth == null || point.RiemannianEast == null) && point.Latitude != null && point.Longitude != null)
        {
            SetNorthEastFromLatitudeLongitude(point);
        }

        if (point.RiemannianNorth == null || point.RiemannianEast == null || point.Latitude == null || point.Longitude == null)
        {
            return null;
        }

        return new ReferencePositionSample(
            point.RiemannianNorth.Value,
            point.RiemannianEast.Value,
            point.Latitude.Value,
            point.Longitude.Value);
    }

    private async Task<CartographicCoordinate?> ConvertReferenceSampleToCartographicAsync(Guid fieldId, ReferencePositionSample sample)
    {
        Guid? persistedProjectionId = CurrentField?.CartographicProjectionID;
        Guid? selectedProjectionId = _cartographicProjection?.MetaInfo?.ID;
        if (persistedProjectionId == null || persistedProjectionId == Guid.Empty)
        {
            logger.LogDebug("Skipping cartographic reference update because the field has no saved cartographic projection");
            return null;
        }

        if (selectedProjectionId != null && selectedProjectionId != Guid.Empty && selectedProjectionId != persistedProjectionId)
        {
            logger.LogDebug("Skipping cartographic reference update because the selected cartographic projection has not been saved yet");
            return null;
        }

        Guid conversionId = Guid.NewGuid();
        DateTimeOffset now = DateTimeOffset.UtcNow;
        FieldCartographicConversionSet conversionSet = new()
        {
            MetaInfo = new MetaInfo
            {
                ID = conversionId,
                HttpHostName = Api.HostNameField,
                HttpHostBasePath = Api.HostBasePathField,
                HttpEndPoint = "FieldCartographicConversionSet/"
            },
            Name = DataUtils.DEFAULT_NAME_CartographicConversionSet,
            Description = "Temporary conversion for cartographic position reference.",
            CreationDate = now,
            LastModificationDate = now,
            FieldID = fieldId,
            CartographicCoordinateList =
            [
                new CartographicCoordinate
                {
                    GeodeticCoordinate = new GeodeticCoordinate
                    {
                        LatitudeWGS84 = sample.Latitude,
                        LongitudeWGS84 = sample.Longitude,
                        VerticalDepthWGS84 = 0
                    }
                }
            ]
        };

        try
        {
            await Api.ClientField.PostFieldCartographicConversionSetAsync(conversionSet);
            FieldCartographicConversionSet calculated = await Api.ClientField.GetFieldCartographicConversionSetByIdAsync(conversionId);
            return calculated.CartographicCoordinateList?.FirstOrDefault();
        }
        finally
        {
            try
            {
                await Api.ClientField.DeleteFieldCartographicConversionSetByIdAsync(conversionId);
            }
            catch
            {
            }
        }
    }

