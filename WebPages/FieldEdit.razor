                return false;
            }

            if (string.IsNullOrWhiteSpace(assignment.Value))
            {
                Snackbar.Add("Identity assignment values cannot be empty", Severity.Warning);
                return false;
            }
        }

        if (_fieldIdentityAssignments
            .Where(assignment => assignment.IdentityID != null)
            .GroupBy(assignment => assignment.IdentityID)
            .Any(group => group.Count() > 1))
        {
            Snackbar.Add("Each field identity can only be assigned once", Severity.Warning);
            return false;
        }

        return true;
    }

