@inject ILogger<FieldEdit> logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IFieldAPIUtils Api
@inject IJSRuntime JSRuntime
@using System.Net.Http.Json
@using MathPoint3DGlobalCoordinates = OSDC.DotnetLibraries.General.Math.Point3DGlobalCoordinates
@using DtoPoint3DGlobalCoordinates = NORCE.Drilling.Field.ModelShared.Point3DGlobalCoordinates

<MudUnitAndReferenceChoiceTag HttpHost="@Api.HostNameUnitConversion"
                              HttpBasePath="@Api.HostBasePathUnitConversion"
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              MeanSeaLevelDepthReferenceSource="@DataUtils.MeanSeaLevelDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@UpdateFieldPositionReferenceName"
                              GeodeticReferenceName="@DataUtils.UnitAndReferenceParameters.GeodeticReferenceName"
                              GeodeticReferenceNameChanged="@DataUtils.UpdateGeodeticReferenceName"
                              CartographicProjectionDatumGeodeticReferenceSource="@DataUtils.CartographicProjectionDatumGeodeticReferenceSource"
                              FieldPositionReferenceSource="@DataUtils.FieldPositionReferenceSource"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource">
    <MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Field</MudText>
    <MudContainer Class="d-flex flex-row align-center mt-4 mb-4">
        <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="Save">Save</MudButton>
        <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="CloseEditorAsync">Close</MudButton>
        <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Primary" OnClick="ExportFieldAsync">Export</MudButton>
        <label class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-filled-size-medium">
            Import
            <InputFile OnChange="ImportFieldAsync" style="display:none" />
        </label>
    </MudContainer>

    <MudExpansionPanels Class="mt-4 mb-4">
        <MudExpansionPanel Text="Description" Expanded="true">
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="@_name" Label="Name" Required="true" ShrinkLabel />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="@_descr" Label="Description" ShrinkLabel />
                </MudItem>
                @if (CartographicProjections != null && CartographicProjections.Count > 0)
                {
                    <MudItem xs="12" md="3">
                        <MudSelect T="CartographicProjectionLight" Value="@_cartographicProjection" ValueChanged="@SetCartographicProjection" Label="Cartographic projection" ShrinkLabel ToStringFunc="@(s => s?.Name)">
                            @foreach (var sph in CartographicProjections)
                            {
                                <MudSelectItem T="CartographicProjectionLight" Value="@sph">@sph.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12" md="3">
                    <MudInputWithUnitAdornment QuantityName="PositionDrilling"
                                               QuantityLabel="Reference North"
                                               DrillingSignalReference="@DrillingSignalReferenceType.Position"
                                               PositionDirection="@PositionDirectionType.North"
                                               SIValueNullable="@_referencePoint.RiemannianNorth"
                                               SIValueNullableChanged="@SetReferenceNorth"
                                               Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudInputWithUnitAdornment QuantityName="PositionDrilling"
                                               QuantityLabel="Reference East"
                                               DrillingSignalReference="@DrillingSignalReferenceType.Position"
                                               PositionDirection="@PositionDirectionType.East"
                                               SIValueNullable="@_referencePoint.RiemannianEast"
                                               SIValueNullableChanged="@SetReferenceEast"
                                               Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudInputWithUnitAdornment QuantityName="PlaneAngleGeodesic"
                                               QuantityLabel="Reference Latitude"
                                               DrillingSignalReference="@DrillingSignalReferenceType.Geodetic"
                                               PositionDirection="@PositionDirectionType.North"
                                               SIValueNullable="@_referencePoint.Latitude"
                                               SIValueNullableChanged="@SetReferenceLatitude"
                                               Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudInputWithUnitAdornment QuantityName="PlaneAngleGeodesic"
                                               QuantityLabel="Reference Longitude"
                                               DrillingSignalReference="@DrillingSignalReferenceType.Geodetic"
                                               PositionDirection="@PositionDirectionType.East"
                                               SIValueNullable="@_referencePoint.Longitude"
                                               SIValueNullableChanged="@SetReferenceLongitude"
                                               Immediate="true" />
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
        <MudExpansionPanel Text="Identities">
            @if (_fieldIdentities.Count > 0)
            {
                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Available</MudText>
                        @foreach (FieldIdentity identity in _fieldIdentities)
                        {
                            <MudButton Class="me-1 mb-1" Variant="@GetIdentityButtonVariant(identity)" Color="@GetIdentityButtonColor(identity)" Size="Size.Small" Disabled="@IsIdentityAssigned(identity)" OnClick="@(() => SelectFieldIdentity(identity))">
                                @GetIdentityDisplayName(identity)
                            </MudButton>
                        }
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex flex-column justify-center">
                        <MudButton Class="mb-2" Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanAssignSelectedIdentity())" OnClick="AssignSelectedIdentity">Assign</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@(!_selectedIdentityAssignmentId.HasValue)" OnClick="UnassignSelectedIdentity">Unassign</MudButton>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Selected</MudText>
                        <MudDataGrid T="FieldIdentityAssignment" Items="@_fieldIdentityAssignments" SelectedItem="@_selectedIdentityAssignment" SelectedItemChanged="SetSelectedIdentityAssignment" Hover="true" Dense="true" Elevation="0">
                            <Columns>
                                <PropertyColumn Property="x => GetIdentityAssignmentDisplayName(x)" Title="Name" Editable="false" />
                                <TemplateColumn Title="Value">
                                    <CellTemplate>
                                        <MudTextField @bind-Value="context.Item.Value" Required="true" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudItem>
                </MudGrid>
            }
        </MudExpansionPanel>
        <MudExpansionPanel Text="Features">
            @if (_fieldFeatureCategories.Count > 0)
            {
                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Available</MudText>
                        <MudExpansionPanels MultiExpansion="true">
                            @foreach (FieldFeatureCategory category in _fieldFeatureCategories)
                            {
                                <MudExpansionPanel Text="@GetCategoryDisplayName(category)">
                                    @foreach (FieldFeatureOption option in category.Options ?? [])
                                    {
                                        <MudButton Class="me-1 mb-1" Variant="@GetOptionButtonVariant(category, option)" Color="@GetOptionButtonColor(category, option)" Size="Size.Small" Disabled="@IsOptionUnavailable(category)" OnClick="@(() => SelectFeatureOption(category, option))">
                                            @option.Name
                                        </MudButton>
                                    }
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex flex-column justify-center">
                        <MudButton Class="mb-2" Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanAssignSelectedOption())" OnClick="AssignSelectedOption">Assign</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@(!_selectedFeatureAssignmentId.HasValue)" OnClick="UnassignSelectedFeature">Unassign</MudButton>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Selected</MudText>
                        <MudDataGrid T="FieldFeatureAssignment" Items="@_fieldFeatureAssignments" SelectedItem="@_selectedFeatureAssignment" SelectedItemChanged="SetSelectedFeatureAssignment" Hover="true" Dense="true" Elevation="0">
                            <Columns>
                                <PropertyColumn Property="x => GetAssignmentDisplayName(x)" Title="Name" Editable="false" />
                                <TemplateColumn Title="From">
                                    <CellTemplate>
                                        <MudDatePicker Date="@ToDateTime(context.Item.FromDate)" DateChanged="@((DateTime? value) => SetAssignmentFromDate(context.Item, value))" Clearable="true" Disabled="@(!CategoryHasValidityPeriod(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="To">
                                    <CellTemplate>
                                        <MudDatePicker Date="@ToDateTime(context.Item.ToDate)" DateChanged="@((DateTime? value) => SetAssignmentToDate(context.Item, value))" Clearable="true" Disabled="@(!CategoryHasValidityPeriod(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudItem>
                </MudGrid>
            }
        </MudExpansionPanel>
        <MudExpansionPanel Text="Memberships">
            @if (_fieldMembershipCategories.Count > 0)
            {
                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Available</MudText>
                        <MudExpansionPanels MultiExpansion="true">
                            @foreach (FieldMembershipCategory category in _fieldMembershipCategories)
                            {
                                <MudExpansionPanel Text="@GetMembershipCategoryDisplayName(category)">
                                    @foreach (FieldMembershipOption option in category.Options ?? [])
                                    {
                                        <MudButton Class="me-1 mb-1" Variant="@GetMembershipOptionButtonVariant(category, option)" Color="@GetMembershipOptionButtonColor(category, option)" Size="Size.Small" Disabled="@IsMembershipOptionUnavailable(category)" OnClick="@(() => SelectMembershipOption(category, option))">
                                            @option.Name
                                        </MudButton>
                                    }
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex flex-column justify-center">
                        <MudButton Class="mb-2" Variant="Variant.Filled" Color="Color.Success" Disabled="@(!CanAssignSelectedMembershipOption())" OnClick="AssignSelectedMembershipOption">Assign</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" Disabled="@(!_selectedMembershipAssignmentId.HasValue)" OnClick="UnassignSelectedMembership">Unassign</MudButton>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Selected</MudText>
                        <MudDataGrid T="FieldMembershipAssignment" Items="@_fieldMembershipAssignments" SelectedItem="@_selectedMembershipAssignment" SelectedItemChanged="SetSelectedMembershipAssignment" Hover="true" Dense="true" Elevation="0">
                            <Columns>
                                <PropertyColumn Property="x => GetMembershipAssignmentDisplayName(x)" Title="Name" Editable="false" />
                                <TemplateColumn Title="From">
                                    <CellTemplate>
                                        <MudDatePicker Date="@ToDateTime(context.Item.FromDate)" DateChanged="@((DateTime? value) => SetMembershipAssignmentFromDate(context.Item, value))" Clearable="true" Disabled="@(!MembershipCategoryHasValidityPeriod(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="To">
                                    <CellTemplate>
                                        <MudDatePicker Date="@ToDateTime(context.Item.ToDate)" DateChanged="@((DateTime? value) => SetMembershipAssignmentToDate(context.Item, value))" Clearable="true" Disabled="@(!MembershipCategoryHasValidityPeriod(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    </MudItem>
                </MudGrid>
            }
        </MudExpansionPanel>
        <MudExpansionPanel Text="Delineation lines">
            <FieldDelineationEditor Lines="@_delineationLines" LineTypes="@_delineationLineTypes" LinesChanged="@RefreshCartographicGridPositionReferenceAsync" />
        </MudExpansionPanel>
    </MudExpansionPanels>
</MudUnitAndReferenceChoiceTag>
@code {
    [Parameter]
    public NORCE.Drilling.Field.ModelShared.Field? CurrentField { get; set; }

    [Parameter]
    public List<CartographicProjectionLight>? CartographicProjections { get; set; }

    [Parameter]
    public List<FieldType>? FieldTypes { get; set; }

    [Parameter]
    public Action? OnUpdate { get; set; }

    // Local variables used to retrieve user-defined parameters
    private CartographicProjectionLight? _cartographicProjection;
    private string? _name;
    private string? _descr;
    private MathPoint3DGlobalCoordinates _referencePoint = new();
    private List<FieldFeatureCategory> _fieldFeatureCategories = new();
    private List<FieldFeatureAssignment> _fieldFeatureAssignments = new();
    private Guid? _selectedFeatureCategoryId;
    private Guid? _selectedFeatureOptionId;
    private Guid? _selectedFeatureAssignmentId;
    private FieldFeatureAssignment? _selectedFeatureAssignment;
    private List<FieldIdentity> _fieldIdentities = new();
    private List<FieldIdentityAssignment> _fieldIdentityAssignments = new();
    private Guid? _selectedIdentityId;
    private Guid? _selectedIdentityAssignmentId;
    private FieldIdentityAssignment? _selectedIdentityAssignment;
    private List<FieldMembershipCategory> _fieldMembershipCategories = new();
    private List<FieldMembershipAssignment> _fieldMembershipAssignments = new();
    private Guid? _selectedMembershipCategoryId;
    private Guid? _selectedMembershipOptionId;
    private Guid? _selectedMembershipAssignmentId;
    private FieldMembershipAssignment? _selectedMembershipAssignment;
    private List<FieldDelineationLine> _delineationLines = new();
    private List<FieldDelineationLineType> _delineationLineTypes = new();
    private string? cleanFieldSnapshot_;
    private bool isRefreshingCartographicGridReference_;
    private bool hasPendingCartographicGridReferenceRefresh_;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            EnsureSupportedDepthReference();
            if (CurrentField != null && CurrentField.MetaInfo != null)
            {
                _cartographicProjection = null;
                if (CurrentField.CartographicProjectionID != null && CurrentField.CartographicProjectionID != Guid.Empty && CartographicProjections != null)
                {
                    CartographicProjectionLight? cartographicProjection = null;
                    foreach (var projection in CartographicProjections)
                    {
                        if (projection.MetaInfo != null && projection.MetaInfo.ID == CurrentField.CartographicProjectionID)
                        {
                            cartographicProjection = projection;
                            break;
                        }
                    }
                    if (cartographicProjection == null)
                    {
                        logger.LogWarning("The Cartographic Projection associated with the Field cannot be found");
                        Snackbar.Add("The Cartographic Projection associated with the Field cannot be found", Severity.Warning);
                    }
                    else
                    {
                        _cartographicProjection = cartographicProjection;
                    }
                }
                _name = CurrentField.Name;
                _descr = CurrentField.Description;
                _referencePoint = CloneReferencePointForEditor(CurrentField.ReferencePoint);
                UpdateFieldPositionReferenceSource();
                _fieldFeatureCategories = await LoadFieldFeatureCategoriesAsync();
                _fieldFeatureAssignments = CloneFeatureAssignments(CurrentField.FieldFeatureAssignments);
                _fieldIdentities = await LoadFieldIdentitiesAsync();
                _fieldIdentityAssignments = CloneIdentityAssignments(CurrentField.FieldIdentityAssignments);
                _fieldMembershipCategories = await LoadFieldMembershipCategoriesAsync();
                _fieldMembershipAssignments = CloneMembershipAssignments(CurrentField.FieldMembershipAssignments);
                _delineationLineTypes = await LoadFieldDelineationLineTypesAsync();
                _delineationLines = CloneDelineationLines(CurrentField.DelineationLines);
                await RefreshCartographicGridPositionReferenceAsync();
                MarkFieldClean();
            }
            else
            {
                logger.LogError("Current Field is null or badly formed");
                Snackbar.Add("Current Field is null or badly formed", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem on Field initialization");
            Snackbar.Add("Problem on Field initialization", Severity.Error);
        }
        await InvokeAsync(() => { StateHasChanged(); });
    }

    private static void EnsureSupportedDepthReference()
    {
        if (string.Equals(DataUtils.UnitAndReferenceParameters.DepthReferenceName, "Sea/Water Level", StringComparison.OrdinalIgnoreCase))
        {
            DataUtils.UnitAndReferenceParameters.DepthReferenceName = "WGS84";
        }
    }

    private Task SetCartographicProjection(CartographicProjectionLight? cartographicProjection)
    {
        _cartographicProjection = cartographicProjection;
        _ = RefreshCartographicGridPositionReferenceAsync();
        return Task.CompletedTask;
    }

    private async Task Save()
    {
        try
        {
            if (CurrentField != null && CurrentField.MetaInfo != null)
            {
                if (!TryValidateFeatureAssignments() || !TryValidateIdentityAssignments() || !TryValidateMembershipAssignments() || !TryValidateDelineationLines())
                {
                    return;
                }

                NORCE.Drilling.Field.ModelShared.Field field = BuildEditedField(DateTimeOffset.UtcNow);
                await Api.ClientField.PutFieldByIdAsync(CurrentField.MetaInfo.ID, field);
                CurrentField = await Api.ClientField.GetFieldByIdAsync(CurrentField.MetaInfo.ID);
                _fieldFeatureAssignments = CloneFeatureAssignments(CurrentField.FieldFeatureAssignments);
                _fieldFeatureCategories = await LoadFieldFeatureCategoriesAsync();
                _fieldIdentityAssignments = CloneIdentityAssignments(CurrentField.FieldIdentityAssignments);
                _fieldIdentities = await LoadFieldIdentitiesAsync();
                _fieldMembershipAssignments = CloneMembershipAssignments(CurrentField.FieldMembershipAssignments);
                _fieldMembershipCategories = await LoadFieldMembershipCategoriesAsync();
                _delineationLines = CloneDelineationLines(CurrentField.DelineationLines);
                _delineationLineTypes = await LoadFieldDelineationLineTypesAsync();
                await RefreshCartographicGridPositionReferenceAsync();
                MarkFieldClean();
                logger.LogInformation("Updated the Field successfully");
                Snackbar.Add("Saved the Field successfully", Severity.Success);
            }
            else
            {
                logger.LogWarning("Problem while saving the Field");
                Snackbar.Add("Problem while saving the Field", Severity.Warning);
            }
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while saving the Field");
            Snackbar.Add("Problem while saving the Field", Severity.Warning);
        }
    }

    private async Task ExportFieldAsync()
    {
        if (CurrentField?.MetaInfo == null)
        {
            Snackbar.Add("No field is available for export", Severity.Warning);
            return;
        }

        NORCE.Drilling.Field.ModelShared.Field field = BuildEditedField(CurrentField.LastModificationDate);
        await DownloadJsonAsync(field, SanitizeFileName($"{_name ?? "field"}.json"));
        Snackbar.Add("Exported field", Severity.Success);
    }

    private async Task ImportFieldAsync(InputFileChangeEventArgs args)
    {
        if (CurrentField?.MetaInfo == null)
        {
            Snackbar.Add("No current field is available for import", Severity.Warning);
            return;
        }

        try
        {
            using System.IO.Stream stream = args.File.OpenReadStream(128 * 1024 * 1024);
            NORCE.Drilling.Field.ModelShared.Field? imported = await System.Text.Json.JsonSerializer.DeserializeAsync<NORCE.Drilling.Field.ModelShared.Field>(
                stream,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (imported == null)
            {
                Snackbar.Add("The selected file does not contain a field", Severity.Warning);
                return;
            }

            ApplyImportedField(imported);
            Snackbar.Add("Imported field into the editor. Save to persist the changes.", Severity.Success);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem importing the Field");
            Snackbar.Add("Error importing field: " + ex.Message, Severity.Error);
        }
    }

    private async Task CloseEditorAsync()
    {
        if (HasUnsavedFieldChanges() && !await ConfirmCloseWithoutSavingAsync())
        {
            return;
        }

        OnUpdate?.Invoke();
    }

    private void MarkFieldClean()
    {
        cleanFieldSnapshot_ = BuildFieldDirtySnapshot();
    }

    private bool HasUnsavedFieldChanges()
    {
        return cleanFieldSnapshot_ != null &&
            !string.Equals(cleanFieldSnapshot_, BuildFieldDirtySnapshot(), StringComparison.Ordinal);
    }

    private string BuildFieldDirtySnapshot()
    {
        return System.Text.Json.JsonSerializer.Serialize(new
        {
            FieldId = CurrentField?.MetaInfo?.ID,
            Name = _name,
            Description = _descr,
            CartographicProjectionId = _cartographicProjection?.MetaInfo?.ID ?? Guid.Empty,
            ReferencePoint = BuildReferencePointDirtySnapshot(_referencePoint),
            FieldFeatureAssignments = BuildFeatureAssignmentDirtySnapshot(_fieldFeatureAssignments),
            FieldIdentityAssignments = BuildIdentityAssignmentDirtySnapshot(_fieldIdentityAssignments),
            FieldMembershipAssignments = BuildMembershipAssignmentDirtySnapshot(_fieldMembershipAssignments),
            DelineationLines = BuildDelineationDirtySnapshot(_delineationLines)
        });
    }

    private async Task<List<FieldFeatureCategory>> LoadFieldFeatureCategoriesAsync()
    {
        try
        {
            List<FieldFeatureCategory>? categories = (List<FieldFeatureCategory>)await Api.ClientField.GetAllFieldFeatureCategoryAsync();
            return categories?
                .Where(category => category?.MetaInfo?.ID != null)
                .OrderBy(category => category.Name, StringComparer.OrdinalIgnoreCase)
                .ToList() ?? [];
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load field feature categories");
            Snackbar.Add("Impossible to load field feature categories", Severity.Warning);
            return [];
        }
    }

    private async Task<List<FieldDelineationLineType>> LoadFieldDelineationLineTypesAsync()
    {
        try
        {
            List<FieldDelineationLineType>? lineTypes = (List<FieldDelineationLineType>)await Api.ClientField.GetAllFieldDelineationLineTypeAsync();
            return lineTypes?
                .Where(lineType => lineType?.MetaInfo?.ID != null)
                .OrderBy(lineType => lineType.Name, StringComparer.OrdinalIgnoreCase)
                .ToList() ?? [];
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load delineation line types");
            Snackbar.Add("Impossible to load delineation line types", Severity.Warning);
            return [];
        }
    }

    private async Task<List<FieldIdentity>> LoadFieldIdentitiesAsync()
    {
        try
        {
            List<FieldIdentity>? identities = (List<FieldIdentity>)await Api.ClientField.GetAllFieldIdentityAsync();
            return identities?
                .Where(identity => identity?.MetaInfo?.ID != null)
                .OrderBy(identity => identity.Name, StringComparer.OrdinalIgnoreCase)
                .ToList() ?? [];
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load field identities");
            Snackbar.Add("Impossible to load field identities", Severity.Warning);
            return [];
        }
    }

    private async Task<List<FieldMembershipCategory>> LoadFieldMembershipCategoriesAsync()
    {
        try
        {
            List<FieldMembershipCategory>? categories = (List<FieldMembershipCategory>)await Api.ClientField.GetAllFieldMembershipCategoryAsync();
            return categories?
                .Where(category => category?.MetaInfo?.ID != null)
                .OrderBy(category => category.Name, StringComparer.OrdinalIgnoreCase)
                .ToList() ?? [];
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load field membership categories");
            Snackbar.Add("Impossible to load field membership categories", Severity.Warning);
            return [];
        }
    }

    private NORCE.Drilling.Field.ModelShared.Field BuildEditedField(DateTimeOffset? lastModificationDate)
    {
        Guid cartographicProjectionID = Guid.Empty;
        if (_cartographicProjection != null && _cartographicProjection.MetaInfo != null && _cartographicProjection.MetaInfo.ID != Guid.Empty)
        {
            cartographicProjectionID = _cartographicProjection.MetaInfo.ID;
        }

        return new NORCE.Drilling.Field.ModelShared.Field
        {
            MetaInfo = CurrentField?.MetaInfo,
            Name = _name,
            Description = _descr,
            CreationDate = CurrentField?.CreationDate,
            LastModificationDate = lastModificationDate,
            CartographicProjectionID = cartographicProjectionID,
            ReferencePoint = CloneReferencePointForStorage(_referencePoint),
            FieldFeatureAssignments = CloneFeatureAssignments(_fieldFeatureAssignments),
            FieldIdentityAssignments = CloneIdentityAssignments(_fieldIdentityAssignments),
            FieldMembershipAssignments = CloneMembershipAssignments(_fieldMembershipAssignments),
            DelineationLines = CloneDelineationLines(_delineationLines)
        };
    }

    private void ApplyImportedField(NORCE.Drilling.Field.ModelShared.Field imported)
    {
        _name = imported.Name;
        _descr = imported.Description;
        _cartographicProjection = FindCartographicProjection(imported.CartographicProjectionID);
        _referencePoint = CloneReferencePointForEditor(imported.ReferencePoint);
        UpdateFieldPositionReferenceSource();
        _fieldFeatureAssignments = CloneFeatureAssignments(imported.FieldFeatureAssignments);
        _fieldIdentityAssignments = CloneIdentityAssignments(imported.FieldIdentityAssignments);
        _fieldMembershipAssignments = CloneMembershipAssignments(imported.FieldMembershipAssignments);
        _delineationLines = CloneDelineationLines(imported.DelineationLines);
        _ = RefreshCartographicGridPositionReferenceAsync();
    }

    private static MathPoint3DGlobalCoordinates CloneReferencePointForEditor(DtoPoint3DGlobalCoordinates? point)
    {
        MathPoint3DGlobalCoordinates editorPoint = new() { TVD = 0, Z = 0 };
        if (point == null)
        {
            return editorPoint;
        }

        if (point.RiemannianNorth != null || point.RiemannianEast != null)
        {
            editorPoint.RiemannianNorth = point.RiemannianNorth;
            editorPoint.RiemannianEast = point.RiemannianEast;
        }
        else
        {
            editorPoint.Latitude = point.Latitude;
            editorPoint.Longitude = point.Longitude;
        }

        return editorPoint;
    }

    private static DtoPoint3DGlobalCoordinates? CloneReferencePointForStorage(MathPoint3DGlobalCoordinates point)
    {
        return IsEmptyReferencePoint(point)
            ? null
            : new DtoPoint3DGlobalCoordinates
            {
                RiemannianNorth = point.RiemannianNorth,
                RiemannianEast = point.RiemannianEast,
                Latitude = point.Latitude,
                Longitude = point.Longitude,
                X = point.RiemannianNorth,
                Y = point.RiemannianEast,
                TVD = 0,
                Z = 0
            };
    }

    private static object? BuildReferencePointDirtySnapshot(MathPoint3DGlobalCoordinates point)
    {
        return IsEmptyReferencePoint(point)
            ? null
            : new
            {
                point.RiemannianNorth,
                point.RiemannianEast,
                point.Latitude,
                point.Longitude
            };
    }

