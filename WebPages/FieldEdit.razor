    private bool TryValidateFeatureAssignments()
    {
        foreach (FieldFeatureAssignment assignment in _fieldFeatureAssignments)
        {
            if (assignment.FeatureCategoryID is not Guid categoryId || assignment.FeatureOptionID is not Guid optionId)
            {
                Snackbar.Add("Feature assignments must have a category and an option", Severity.Warning);
                return false;
            }

            FieldFeatureCategory? category = FindFeatureCategory(categoryId);
            if (category == null || !CategoryContainsOption(category, optionId))
            {
                Snackbar.Add("Feature assignments must reference existing categories and options", Severity.Warning);
                return false;
            }

            if (!category.HasValidityPeriod)
            {
                assignment.FromDate = null;
                assignment.ToDate = null;
            }

            if (assignment.FromDate != null && assignment.ToDate != null && assignment.FromDate > assignment.ToDate)
            {
                Snackbar.Add("Feature assignment From date cannot be after To date", Severity.Warning);
                return false;
            }
        }

        foreach (FieldFeatureCategory category in _fieldFeatureCategories.Where(category => category.IsExclusive))
        {
            if (category.MetaInfo?.ID is not Guid categoryId)
            {
                continue;
            }

            List<FieldFeatureAssignment> categoryAssignments = _fieldFeatureAssignments
                .Where(assignment => assignment.FeatureCategoryID == categoryId)
                .ToList();

            if (!category.HasValidityPeriod && categoryAssignments.Count > 1)
            {
                Snackbar.Add($"Only one option can be assigned for '{category.Name}'", Severity.Warning);
                return false;
            }

            if (category.HasValidityPeriod && HasOverlappingAssignments(categoryAssignments))
            {
                Snackbar.Add($"Feature assignment periods cannot overlap for '{category.Name}'", Severity.Warning);
                return false;
            }
        }

        return true;
    }

    private static bool HasOverlappingAssignments(List<FieldFeatureAssignment> assignments)
    {
        for (int i = 0; i < assignments.Count; i++)
        {
            for (int j = i + 1; j < assignments.Count; j++)
            {
                if (IntervalsOverlap(assignments[i], assignments[j]))
                {
                    return true;
                }
            }
        }

        return false;
    }

    private static bool IntervalsOverlap(FieldFeatureAssignment first, FieldFeatureAssignment second)
    {
        DateTimeOffset firstStart = first.FromDate ?? DateTimeOffset.MinValue;
        DateTimeOffset firstEnd = first.ToDate ?? DateTimeOffset.MaxValue;
        DateTimeOffset secondStart = second.FromDate ?? DateTimeOffset.MinValue;
        DateTimeOffset secondEnd = second.ToDate ?? DateTimeOffset.MaxValue;
        return firstStart <= secondEnd && secondStart <= firstEnd;
    }

