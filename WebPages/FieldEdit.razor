    {
        DataUtils.UnitAndReferenceParameters.PositionReferenceName = value;
    }

    private bool TryValidateDelineationLines()
    {
        foreach (FieldDelineationLine line in _delineationLines)
        {
            if (string.IsNullOrWhiteSpace(line.Name))
            {
                Snackbar.Add("Delineation line names cannot be empty", Severity.Warning);
                return false;
            }
            if (line.Margin is < 0)
            {
                Snackbar.Add("Delineation line margins cannot be negative", Severity.Warning);
                return false;
            }
            if (line.TopDepth != null && line.BottomDepth != null && line.TopDepth > line.BottomDepth)
            {
                Snackbar.Add("Delineation line top depth must be smaller than or equal to bottom depth", Severity.Warning);
                return false;
            }
            if (line.Points != null && line.Points.Any(point => point.RiemannianNorth == null || point.RiemannianEast == null))
            {
                Snackbar.Add("Delineation line points must have north and east coordinates", Severity.Warning);
                return false;
            }
        }

        return true;
    }

    private static List<FieldDelineationLine> CloneDelineationLines(IEnumerable<FieldDelineationLine>? lines)
    {
        return lines?
            .Select(line => new FieldDelineationLine
            {
                ID = line.ID == Guid.Empty ? Guid.NewGuid() : line.ID,
                DelineationLineTypeID = line.DelineationLineTypeID,
                LineType = line.LineType,
                Name = line.Name,
                Description = line.Description,
                Margin = line.Margin,
                TopDepth = line.TopDepth,
                BottomDepth = line.BottomDepth,
                Points = ClonePoints(line.Points),
                CalculatedBoundaryLines = CloneBoundaryLines(line.CalculatedBoundaryLines)
            })
            .ToList() ?? new List<FieldDelineationLine>();
    }

    private static List<FieldDelineationBoundaryLine> CloneBoundaryLines(IEnumerable<FieldDelineationBoundaryLine>? lines)
    {
        return lines?
            .Select(line => new FieldDelineationBoundaryLine
            {
                ID = line.ID == Guid.Empty ? Guid.NewGuid() : line.ID,
                IsInteriorBoundary = line.IsInteriorBoundary,
                IsClosed = line.IsClosed,
                Points = ClonePoints(line.Points)
            })
            .ToList() ?? new List<FieldDelineationBoundaryLine>();
    }

    private static List<Point3DGlobalCoordinates> ClonePoints(IEnumerable<Point3DGlobalCoordinates>? points)
    {
        return points?
            .Select(ClonePoint)
            .ToList() ?? new List<Point3DGlobalCoordinates>();
    }

    private static Point3DGlobalCoordinates ClonePoint(Point3DGlobalCoordinates point)
    {
        Point3DGlobalCoordinates clone = new()
        {
            RiemannianNorth = point.RiemannianNorth,
            RiemannianEast = point.RiemannianEast,
            Latitude = point.Latitude,
            Longitude = point.Longitude,
            TVD = 0,
            Z = 0
        };

        if ((clone.Latitude == null || clone.Longitude == null) &&
            clone.RiemannianNorth != null &&
            clone.RiemannianEast != null)
        {
            SetLatitudeLongitudeFromNorthEast(clone);
        }
        else if ((clone.RiemannianNorth == null || clone.RiemannianEast == null) &&
            clone.Latitude != null &&
            clone.Longitude != null)
        {
            SetNorthEastFromLatitudeLongitude(clone);
        }

        clone.X = clone.RiemannianNorth;
        clone.Y = clone.RiemannianEast;
        clone.TVD = 0;
        clone.Z = 0;
        return clone;
    }

    private static void SetLatitudeLongitudeFromNorthEast(Point3DGlobalCoordinates point)
    {
        if (point.RiemannianNorth == null || point.RiemannianEast == null)
        {
            return;
        }

        double latitude = LatitudeFromMeridianDistance(point.RiemannianNorth.Value);
        double parallelRadius = ParallelRadius(latitude);
        point.Latitude = latitude;
        point.Longitude = Math.Abs(parallelRadius) < 1e-12 ? null : point.RiemannianEast.Value / parallelRadius;
    }

    private static void SetNorthEastFromLatitudeLongitude(Point3DGlobalCoordinates point)
    {
        if (point.Latitude == null || point.Longitude == null)
        {
            return;
        }

        point.RiemannianNorth = MeridianDistance(point.Latitude.Value);
        point.RiemannianEast = ParallelRadius(point.Latitude.Value) * point.Longitude.Value;
        point.X = point.RiemannianNorth;
        point.Y = point.RiemannianEast;
    }

    private static double LatitudeFromMeridianDistance(double meridianDistance)
    {
        double latitude = meridianDistance / EarthSemiMajorAxisWGS84;
        for (int i = 0; i < 12; i++)
        {
            double residual = MeridianDistance(latitude) - meridianDistance;
            double derivative = MeridianRadiusOfCurvature(latitude);
            if (Math.Abs(derivative) < 1e-12)
            {
                break;
            }

            double correction = residual / derivative;
            latitude -= correction;
            if (Math.Abs(correction) < 1e-13)
            {
                break;
            }
        }

        return latitude;
    }

    private static double MeridianDistance(double latitude)
    {
        double e2 = EarthFirstEccentricitySquaredWGS84;
        double e4 = e2 * e2;
        double e6 = e4 * e2;
        double a0 = 1.0 - e2 / 4.0 - 3.0 * e4 / 64.0 - 5.0 * e6 / 256.0;
        double a2 = 3.0 / 8.0 * (e2 + e4 / 4.0 + 15.0 * e6 / 128.0);
        double a4 = 15.0 / 256.0 * (e4 + 3.0 * e6 / 4.0);
        double a6 = 35.0 * e6 / 3072.0;
        return EarthSemiMajorAxisWGS84 * (a0 * latitude - a2 * Math.Sin(2.0 * latitude) + a4 * Math.Sin(4.0 * latitude) - a6 * Math.Sin(6.0 * latitude));
    }

    private static double MeridianRadiusOfCurvature(double latitude)
    {
        double e2 = EarthFirstEccentricitySquaredWGS84;
        double sinLatitude = Math.Sin(latitude);
        return EarthSemiMajorAxisWGS84 * (1.0 - e2) / Math.Pow(1.0 - e2 * sinLatitude * sinLatitude, 1.5);
    }

    private static double ParallelRadius(double latitude)
    {
        double e2 = EarthFirstEccentricitySquaredWGS84;
        double sinLatitude = Math.Sin(latitude);
        double cosLatitude = Math.Cos(latitude);
        return EarthSemiMajorAxisWGS84 * cosLatitude / Math.Sqrt(1.0 - e2 * sinLatitude * sinLatitude);
    }

    private const double EarthSemiMajorAxisWGS84 = 6378137.0;
    private const double EarthFirstEccentricitySquaredWGS84 = 6.6943799901413165e-3;

    private static object BuildDelineationDirtySnapshot(IEnumerable<FieldDelineationLine> lines)
    {
        return lines.Select(line => new
        {
            line.ID,
            line.DelineationLineTypeID,
            line.LineType,
            line.Name,
            line.Description,
            line.Margin,
            line.TopDepth,
            line.BottomDepth,
            Points = BuildPointDirtySnapshot(line.Points),
            Boundaries = line.CalculatedBoundaryLines?.Select(boundary => new
            {
                boundary.ID,
                boundary.IsInteriorBoundary,
                boundary.IsClosed,
                Points = BuildPointDirtySnapshot(boundary.Points)
            }).ToList()
        }).ToList();
    }

    private static object BuildPointDirtySnapshot(IEnumerable<Point3DGlobalCoordinates>? points)
    {
        if (points == null)
        {
            return new List<object>();
        }

        return points.Select(point => new
        {
            point.RiemannianNorth,
            point.RiemannianEast,
            point.Latitude,
            point.Longitude
        }).ToList();
    }

    private async Task DownloadJsonAsync<T>(T value, string fileName)
    {
        string json = System.Text.Json.JsonSerializer.Serialize(value, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
            Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
        });
        string base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(json));
        string encodedFileName = System.Text.Json.JsonEncodedText.Encode(fileName).ToString();
        string script =
            "(() => {" +
            $"const binary = atob(\"{base64}\");" +
            "const bytes = new Uint8Array(binary.length);" +
            "for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);" +
            "const blob = new Blob([bytes], { type: \"application/json;charset=utf-8\" });" +
            "const url = URL.createObjectURL(blob);" +
            "const anchor = document.createElement(\"a\");" +
            "anchor.href = url;" +
            $"anchor.download = \"{encodedFileName}\";" +
            "document.body.appendChild(anchor);" +
            "anchor.click();" +
            "anchor.remove();" +
            "URL.revokeObjectURL(url);" +
            "})()";
        await JSRuntime.InvokeVoidAsync("eval", script);
    }

    private static string SanitizeFileName(string fileName)
    {
        char[] invalidChars = Path.GetInvalidFileNameChars();
        string sanitized = new(fileName.Select(character => invalidChars.Contains(character) ? '_' : character).ToArray());
        return string.IsNullOrWhiteSpace(sanitized) ? "field.json" : sanitized;
    }

    private async Task<bool> ConfirmCloseWithoutSavingAsync()
    {
        bool? result = await DialogService.ShowMessageBox(
            "Unsaved changes",
            "Some changes have not been saved. Close without saving?",
            yesText: "Close without saving",
            cancelText: "Stay",
            options: new DialogOptions
            {
                CloseOnEscapeKey = true,
                FullWidth = false,
                MaxWidth = MaxWidth.ExtraSmall
            });

        return result == true;
    }
