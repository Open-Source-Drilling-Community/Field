@page "/FieldSurveyRuns"
@inject ILogger<FieldSurveyRuns> logger
@inject ISnackbar Snackbar
@inject IFieldAPIUtils Api
@using System.Net.Http.Json
@using System.Text.Json
@using FieldModelShared = NORCE.Drilling.Field.ModelShared

<MudUnitAndReferenceChoiceTag HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.SeaWaterLevelDepthReferenceSource"
                              MeanSeaLevelDepthReferenceSource="@DataUtils.MeanSeaLevelDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@DataUtils.UpdatePositionReferenceName"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource"
                              >
    @if (fieldList == null || clusterList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <MudStack Spacing="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h5">Field Survey Runs</MudText>
                        <MudText Typo="Typo.body2">All wellbore survey runs for the selected field, shown in 3D and as a horizontal projection.</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="8" md="4">
                        <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                            @foreach (FieldModelShared.Field field in AvailableFields)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="ReloadSelectedFieldAsync" Disabled="@(selectedFieldId == null)">Reload</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="2">
                        <MudSelect Label="Type" T="string" Value="@selectedSurveyRunTypeFilter" ValueChanged="OnSurveyRunFilterChanged" ShrinkLabel>
                            <MudSelectItem T="string" Value="@SurveyRunTypeFilterAll">All</MudSelectItem>
                            <MudSelectItem T="string" Value="@SurveyRunTypeFilterPlanned">Planned</MudSelectItem>
                            <MudSelectItem T="string" Value="@SurveyRunTypeFilterActual">Actual</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
                <MudDivider Class="my-3" />
                <MudGrid>
                    <MudItem xs="12" sm="4" md="3">
                        <MudNumericField @bind-Value="ellipseConfidenceFactor"
                                         Label="Confidence factor"
                                         Min="0.0"
                                         Max="1.0"
                                         Step="0.01"
                                         ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="CalculateUncertaintyEllipsesAsync"
                                   Disabled="@(surveyRunList.Count == 0 || isLoadingSurveyRuns || isCalculatingEllipses)">
                            Calculate Ellipses
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   OnClick="ClearUncertaintyEllipses"
                                   Disabled="@(ellipseResultsBySurveyRun.Count == 0 || isCalculatingEllipses)">
                            Clear Ellipses
                        </MudButton>
                    </MudItem>
                    @if (isCalculatingEllipses)
                    {
                        <MudItem xs="12" md="3">
                            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mt-4" />
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@errorMessage</MudAlert>
            }
            else if (isLoadingSurveyRuns)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Loading survey runs for the selected field.</MudAlert>
            }
            else if (selectedFieldId == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">Select a field to display its wellbore survey runs.</MudAlert>
            }
            else if (surveyRunList.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No survey runs were found for the selected field.</MudAlert>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">3D View</MudText>
                            <Scatter3DPlot XUnit="PositionDrilling"
                                           YUnit="PositionDrilling"
                                           ZUnit="DepthDrilling"
                                           NameList="@Plot3DNames"
                                           ModeFlagList="@Plot3DModeFlags"
                                           ColorList="@Plot3DColors"
                                           XValuesList="@Plot3DEastValuesList"
                                           YValuesList="@Plot3DNorthValuesList"
                                           ZValuesList="@Plot3DTvdValuesList"
                                           XAxisTitle="Easting"
                                           YAxisTitle="Northing"
                                           ZAxisTitle="TVD"
                                           PlotTitle="Field survey runs"
                                           PlotHeight="600"
                                           ZAxisReversed="true"
                                           XAxisUsesPositionReference="true"
                                           YAxisUsesPositionReference="true"
                                           ZAxisUsesDepthReference="true"
                                           XAxisPositionDirection="@PositionDirectionType.East"
                                           YAxisPositionDirection="@PositionDirectionType.North"
                                           CameraIsAboveSceneChanged="OnCameraIsAboveSceneChanged"
                                           ShowLegends="@Plot3DShowLegends" />
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" xl="6">
                        <MudPaper Class="pa-4" Elevation="2">
                            <MudText Typo="Typo.h6">Horizontal Projection</MudText>
                            <ScatterPlot XUnit="PositionDrilling"
                                         YUnit="PositionDrilling"
                                         NameList="@PlotHorizontalNames"
                                         ModeFlagList="@PlotHorizontalModeFlags"
                                         ColorList="@PlotHorizontalColors"
                                         XValuesList="@PlotHorizontalEastValuesList"
                                         YValuesList="@PlotHorizontalNorthValuesList"
                                         LineDashList="@PlotHorizontalLineDashes"
                                         XAxisTitle="Easting"
                                         YAxisTitle="Northing"
                                         PlotTitle="Horizontal projection"
                                         PlotHeight="600"
                                         AspectRatio="1"
                                         XAxisUsesPositionReference="true"
                                         YAxisUsesPositionReference="true"
                                         XAxisPositionDirection="@PositionDirectionType.East"
                                         YAxisPositionDirection="@PositionDirectionType.North"
                                         ShowLegends="@PlotHorizontalShowLegends" />
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">Legend</MudText>
                    <MudGrid>
                        @foreach (var trace in plotTraces.Where(trace => trace.ShowLegend))
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <span style="@($"width:18px;height:18px;border-radius:50%;display:inline-block;background:{trace.Color};")"></span>
                                    <MudText Typo="Typo.body2">@trace.Name</MudText>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        </MudStack>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    private List<FieldModelShared.Field>? fieldList;
    private List<FieldModelShared.Cluster>? clusterList;
    private List<FieldModelShared.SurveyRunLight> surveyRunLightList = [];
    private List<FieldModelShared.SurveyRun> surveyRunList = [];
    private List<FieldModelShared.FieldDelineationLine> selectedFieldDelineationLines = [];
    private Guid? selectedFieldId;
    private string? errorMessage;
    private bool isLoadingSurveyRuns;
    private const string SurveyRunTypeFilterAll = "All";
    private const string SurveyRunTypeFilterPlanned = "Planned";
    private const string SurveyRunTypeFilterActual = "Actual";
    private string selectedSurveyRunTypeFilter = SurveyRunTypeFilterAll;
    private bool isCalculatingEllipses;
    private double ellipseConfidenceFactor = 0.95;
    private bool cameraIsAboveScene = true;

    private List<PlotTrace> plotTraces = [];
    private Dictionary<Guid, List<FieldModelShared.SurveyStationEllipseResult>> ellipseResultsBySurveyRun = [];

    private List<string> PlotNames => plotTraces.Select(trace => trace.Name).ToList();
    private List<int> PlotModeFlags => plotTraces.Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotColors => plotTraces.Select(trace => trace.Color).ToList();
    private List<bool> PlotShowLegends => plotTraces.Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> NorthValuesList => plotTraces.Select(trace => trace.NorthValues).ToList();
    private List<List<object>> EastValuesList => plotTraces.Select(trace => trace.EastValues).ToList();
    private List<List<object>> TvdValuesList => plotTraces.Select(trace => trace.TvdValues).ToList();
    private List<string> Plot3DNames => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Name).ToList();
    private List<int> Plot3DModeFlags => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ModeFlag).ToList();
    private List<string> Plot3DColors => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.Color).ToList();
    private List<bool> Plot3DShowLegends => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.ShowLegend).ToList();
    private List<List<object>> Plot3DNorthValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> Plot3DEastValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.EastValues).ToList();
    private List<List<object>> Plot3DTvdValuesList => plotTraces.Where(trace => trace.ShowIn3D).Select(trace => trace.TvdValues).ToList();
    private List<string> PlotHorizontalNames => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Name).ToList();
    private List<int> PlotHorizontalModeFlags => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ModeFlag).ToList();
    private List<string> PlotHorizontalColors => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.Color).ToList();
    private List<bool> PlotHorizontalShowLegends => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.ShowLegend).ToList();
    private List<string> PlotHorizontalLineDashes => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.LineDash).ToList();
    private List<List<object>> PlotHorizontalNorthValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.NorthValues).ToList();
    private List<List<object>> PlotHorizontalEastValuesList => plotTraces.Where(trace => trace.ShowInHorizontal).Select(trace => trace.EastValues).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            logger.LogInformation("Trying to load list of Fields from client: {Host}", Api.HostNameField);
            Task<ICollection<FieldModelShared.Field>> fieldTask = Api.ClientField.GetAllFieldAsync();
            Task<ICollection<FieldModelShared.Cluster>> clusterTask = Api.ClientCluster.GetAllClusterAsync();
            fieldList = (await fieldTask).OrderBy(field => field.Name).ToList();
            clusterList = (await clusterTask).OrderBy(cluster => cluster.Name).ToList();
            selectedFieldId = null;
            FieldReferenceDatumUtils.Clear();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading fields");
            errorMessage = "Unable to load fields.";
            Snackbar.Add(errorMessage, Severity.Error);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading fields");
            errorMessage = "Unable to load fields.";
            Snackbar.Add(errorMessage, Severity.Error);
        }

        await InvokeAsync(StateHasChanged);
    }

    private List<FieldModelShared.Field> AvailableFields =>
        fieldList?
            .Where(field => field?.MetaInfo != null)
            .OrderBy(field => field.Name)
            .ToList() ?? [];

    private async Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId = fieldId;
        if (selectedFieldId is Guid selected)
        {
            await ApplySelectedFieldReferenceValuesAsync(selected);
            await LoadSurveyRunsAsync(selected);
        }
        else
        {
            surveyRunLightList.Clear();
            surveyRunList.Clear();
            selectedFieldDelineationLines.Clear();
            ClearPlots();
            FieldReferenceDatumUtils.Clear();
            errorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadSelectedFieldAsync()
    {
        if (selectedFieldId is Guid fieldId)
        {
            await ApplySelectedFieldReferenceValuesAsync(fieldId);
            await LoadSurveyRunsAsync(fieldId);
        }
    }


    private async Task OnSurveyRunFilterChanged(string value)
    {
        selectedSurveyRunTypeFilter = string.IsNullOrWhiteSpace(value) ? SurveyRunTypeFilterAll : value;
        await ReloadCurrentSelectionAsync();
    }

    private bool MatchesSurveyRunFilters(FieldModelShared.SurveyRunLight surveyRun)
    {
        bool typeMatches = selectedSurveyRunTypeFilter == SurveyRunTypeFilterAll ||
            string.Equals(surveyRun.SurveyRunType.ToString(), selectedSurveyRunTypeFilter, StringComparison.OrdinalIgnoreCase);
        return typeMatches;
    }

    private async Task ReloadCurrentSelectionAsync()
    {
        if (selectedFieldId is Guid fieldId)
        {
            await ApplySelectedFieldReferenceValuesAsync(fieldId);
            await LoadSurveyRunsAsync(fieldId);
        }
    }

    private async Task ApplySelectedFieldReferenceValuesAsync(Guid fieldId)
    {
        FieldReferenceDatumUtils.Apply(
            await FieldReferenceDatumUtils.ResolveForFieldAsync(Api, fieldId, clusterList));
    }

    private async Task LoadSurveyRunsAsync(Guid fieldId)
    {
        try
        {
            errorMessage = null;
            isLoadingSurveyRuns = true;
            ellipseResultsBySurveyRun.Clear();
            surveyRunLightList.Clear();
            surveyRunList.Clear();
            selectedFieldDelineationLines.Clear();
            ClearPlots();
            await InvokeAsync(StateHasChanged);
            selectedFieldDelineationLines = await LoadSelectedFieldDelineationLinesAsync(fieldId);
            logger.LogInformation("Loading survey run light data for field {FieldId}", fieldId);
            surveyRunLightList = (await Api.ClientTrajectory.GetAllSurveyRunLightAsync(fieldId: fieldId)).Where(MatchesSurveyRunFilters).OrderBy(surveyRun => surveyRun.Name).ToList();

            List<Task<FieldModelShared.SurveyRun>> detailTasks = surveyRunLightList
                .Where(light => light?.MetaInfo != null && light.MetaInfo.ID != Guid.Empty)
                .Select(light => LoadSurveyRunWithSurveyStationsAsync(light.MetaInfo.ID))
                .ToList();

            surveyRunList = (await Task.WhenAll(detailTasks))
                .Where(surveyRun => surveyRun != null)
                .OrderBy(surveyRun => surveyRun.Name)
                .ToList();

            UpdatePlots();
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while loading survey runs for field {FieldId}", fieldId);
            errorMessage = "Unable to load survey runs for the selected field.";
            Snackbar.Add(errorMessage, Severity.Error);
            surveyRunLightList.Clear();
            surveyRunList.Clear();
            selectedFieldDelineationLines.Clear();
            ClearPlots();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Unexpected problem while loading survey runs for field {FieldId}", fieldId);
            errorMessage = "Unable to load survey runs for the selected field.";
            Snackbar.Add(errorMessage, Severity.Error);
            surveyRunLightList.Clear();
            surveyRunList.Clear();
            selectedFieldDelineationLines.Clear();
            ClearPlots();
        }
        finally
        {
            isLoadingSurveyRuns = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task<FieldModelShared.SurveyRun> LoadSurveyRunWithSurveyStationsAsync(Guid surveyRunId)
    {
        FieldModelShared.SurveyRun surveyRun = await Api.ClientTrajectory.GetSurveyRunByIdAsync(surveyRunId);
        int chunkCount = await Api.HttpClientTrajectory.GetFromJsonAsync<int>($"SurveyRun/{surveyRunId}/SurveyStations/ChunkCount");
        if (chunkCount <= 0)
        {
            surveyRun.SurveyStationList ??= [];
            return surveyRun;
        }

        List<FieldModelShared.SurveyStation> stations = [];
        for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
        {
            FieldModelShared.SurveyStationChunk? chunk = await Api.HttpClientTrajectory.GetFromJsonAsync<SurveyStationChunk>($"SurveyRun/{surveyRunId}/SurveyStations/Chunks/{chunkIndex}");
            if (chunk?.SurveyStationList is { Count: > 0 } chunkStations)
            {
                stations.AddRange(chunkStations);
            }
        }

        surveyRun.SurveyStationList = stations;
        return surveyRun;
    }

    private async Task<List<FieldModelShared.FieldDelineationLine>> LoadSelectedFieldDelineationLinesAsync(Guid fieldId)
    {
        try
        {
            FieldModelShared.Field field = await Api.ClientField.GetFieldByIdAsync(fieldId);
            return field.DelineationLines?
                .Where(line => line?.Points?.Count >= 2)
                .ToList() ?? [];
        }
        catch (Exception ex)
        {
            logger.LogWarning(ex, "Unable to load delineation lines for field {FieldId}", fieldId);
            return [];
        }
    }

    private void UpdatePlots()
    {
        ClearPlots();
        int colorIndex = 0;
        List<PlotTrace> nextPlotTraces = [];

        foreach (FieldModelShared.SurveyRun surveyRun in surveyRunList)
        {
            if (surveyRun?.SurveyStationList == null || surveyRun.SurveyStationList.Count == 0)
            {
                continue;
            }

            List<object> northValues = [];
            List<object> eastValues = [];
            List<object> tvdValues = [];

            foreach (FieldModelShared.SurveyStation station in surveyRun.SurveyStationList)
            {
                AppendPoint(station, northValues, eastValues, tvdValues);
            }

            if (northValues.Count < 2 || northValues.Count != eastValues.Count || northValues.Count != tvdValues.Count)
            {
                continue;
            }

            if (surveyRun.MetaInfo?.ID is not Guid surveyRunId)
            {
                continue;
            }

            nextPlotTraces.Add(new PlotTrace(
                string.IsNullOrWhiteSpace(surveyRun.Name) ? "survey run" : surveyRun.Name,
                1,
                Colors[colorIndex % Colors.Length],
                true,
                northValues,
                eastValues,
                tvdValues));

            if (ellipseResultsBySurveyRun.TryGetValue(surveyRunId, out List<FieldModelShared.SurveyStationEllipseResult>? ellipseResults))
            {
                AddEllipseTraces(nextPlotTraces, surveyRun.SurveyStationList, ellipseResults, Colors[colorIndex % Colors.Length], surveyRun.Name);
            }
            colorIndex++;
        }

        AppendDelineationTraces(nextPlotTraces);
        plotTraces = nextPlotTraces;
    }

    private async Task OnCameraIsAboveSceneChanged(bool value)
    {
        if (cameraIsAboveScene == value)
        {
            return;
        }

        cameraIsAboveScene = value;
        UpdatePlots();
        await InvokeAsync(StateHasChanged);
    }

    private void AppendDelineationTraces(List<PlotTrace> traces)
    {
        if (selectedFieldDelineationLines.Count == 0)
        {
            return;
        }

        double planeTvd = GetDelineationPlaneTvd(traces);
        int index = 0;
        foreach (FieldModelShared.FieldDelineationLine line in selectedFieldDelineationLines)
        {
            string color = Colors[(index + 4) % Colors.Length];
            string name = string.IsNullOrWhiteSpace(line.Name) ? $"delineation {index + 1}" : line.Name;
            if (BuildDelineationTrace(name, line.Points, color, "solid", true, planeTvd) is { } trace)
            {
                traces.Add(trace);
            }

            int boundaryIndex = 1;
            foreach (FieldModelShared.FieldDelineationBoundaryLine boundary in line.CalculatedBoundaryLines ?? [])
            {
                if (BuildDelineationTrace($"{name} boundary {boundaryIndex}", boundary.Points, color, "dash", false, planeTvd) is { } boundaryTrace)
                {
                    traces.Add(boundaryTrace);
                }
                boundaryIndex++;
            }
            index++;
        }
    }

    private double GetDelineationPlaneTvd(IEnumerable<PlotTrace> traces)
    {
        List<double> tvdValues = traces
            .SelectMany(trace => trace.TvdValues)
            .SelectMany(ToDoubleValue)
            .ToList();
        if (tvdValues.Count == 0)
        {
            return 0.0;
        }

        return cameraIsAboveScene ? tvdValues.Min() : tvdValues.Max();
    }

    private static PlotTrace? BuildDelineationTrace(
        string name,
        ICollection<FieldModelShared.Point3DGlobalCoordinates>? points,
        string color,
        string lineDash,
        bool showLegend,
        double planeTvd)
    {
        if (points == null || points.Count < 2)
        {
            return null;
        }

        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        foreach (FieldModelShared.Point3DGlobalCoordinates point in points)
        {
            if (point.RiemannianNorth is not { } north || point.RiemannianEast is not { } east)
            {
                continue;
            }

            AppendPointValues(north, east, planeTvd, northValues, eastValues, tvdValues);
        }

        return northValues.Count >= 2 && northValues.Count == eastValues.Count
            ? new PlotTrace(name, 1, color, showLegend, northValues, eastValues, tvdValues, true, true, lineDash)
            : null;
    }

    private static IEnumerable<double> ToDoubleValue(object value)
    {
        if (TryGetDouble(value, out double converted))
        {
            yield return converted;
        }
    }

    private async Task CalculateUncertaintyEllipsesAsync()
    {
        if (surveyRunList.Count == 0)
        {
            return;
        }

        try
        {
            isCalculatingEllipses = true;
            ellipseResultsBySurveyRun.Clear();
            await InvokeAsync(StateHasChanged);

            Dictionary<Guid, List<FieldModelShared.SurveyStationEllipseResult>> nextEllipseResultsBySurveyRun = [];
            foreach (FieldModelShared.SurveyRun surveyRun in surveyRunList)
            {
                if (surveyRun.MetaInfo?.ID is not Guid surveyRunId ||
                    surveyRun.SurveyStationList is not { Count: > 0 } surveyStations)
                {
                    continue;
                }

                FieldModelShared.SurveyStationEllipseCalculation order = new()
                {
                    MetaInfo = new FieldModelShared.MetaInfo { ID = Guid.NewGuid() },
                    Name = $"{surveyRun.Name} uncertainty ellipses",
                    Description = string.Empty,
                    CreationDate = DateTimeOffset.UtcNow,
                    LastModificationDate = DateTimeOffset.UtcNow,
                    ConfidenceFactor = ellipseConfidenceFactor,
                    SurveyStationList = surveyStations
                };

                HttpResponseMessage response = await Api.HttpClientTrajectory.PostAsJsonAsync("SurveyStationEllipseCalculation", order);
                response.EnsureSuccessStatusCode();
                FieldModelShared.SurveyStationEllipseCalculation? result = await response.Content.ReadFromJsonAsync<FieldModelShared.SurveyStationEllipseCalculation>();
                if (result?.SurveyStationEllipseResultList is { Count: > 0 } ellipseResults)
                {
                    nextEllipseResultsBySurveyRun[surveyRunId] = ellipseResults.ToList();
                }
            }

            ellipseResultsBySurveyRun = nextEllipseResultsBySurveyRun;
            UpdatePlots();
            if (ellipseResultsBySurveyRun.Count == 0)
            {
                Snackbar.Add("No uncertainty ellipses could be calculated.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while calculating uncertainty ellipses");
            Snackbar.Add("Problem while calculating uncertainty ellipses: " + ex.Message, Severity.Error);
        }
        finally
        {
            isCalculatingEllipses = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ClearUncertaintyEllipses()
    {
        ellipseResultsBySurveyRun.Clear();
        UpdatePlots();
    }

    private static void AddEllipseTraces(
        List<PlotTrace> traces,
        ICollection<FieldModelShared.SurveyStation> surveyStations,
        IReadOnlyList<FieldModelShared.SurveyStationEllipseResult> ellipseResults,
        string color,
        string? surveyRunName)
    {
        bool horizontalLegendShown = false;
        bool perpendicularLegendShown = false;
        foreach ((FieldModelShared.SurveyStation station, FieldModelShared.SurveyStationEllipseResult result) in SelectEvenlySpacedEllipses(surveyStations, ellipseResults))
        {
            if (BuildHorizontalEllipseTrace(station, result.HorizontalEllipse, color, !horizontalLegendShown, surveyRunName) is { } horizontalTrace)
            {
                traces.Add(horizontalTrace);
                horizontalLegendShown = true;
            }
            if (BuildPerpendicularEllipseTrace(station, result.PerpendicularEllipse, color, !perpendicularLegendShown, surveyRunName) is { } perpendicularTrace)
            {
                traces.Add(perpendicularTrace);
                perpendicularLegendShown = true;
            }
        }
    }

    private static IReadOnlyList<(FieldModelShared.SurveyStation Station, FieldModelShared.SurveyStationEllipseResult Result)> SelectEvenlySpacedEllipses(
        ICollection<FieldModelShared.SurveyStation> surveyStations,
        IReadOnlyList<FieldModelShared.SurveyStationEllipseResult> ellipseResults)
    {
        List<(FieldModelShared.SurveyStation Station, FieldModelShared.SurveyStationEllipseResult Result)> candidates = [];
        foreach (FieldModelShared.SurveyStationEllipseResult result in ellipseResults)
        {
            FieldModelShared.SurveyStation? station = FindStation(surveyStations, result.MD);
            if (station != null)
            {
                candidates.Add((station, result));
            }
        }

        if (candidates.Count <= MaxDisplayedUncertaintyEllipses)
        {
            return candidates;
        }

        List<(FieldModelShared.SurveyStation Station, FieldModelShared.SurveyStationEllipseResult Result)> ordered = candidates
            .OrderBy(candidate => candidate.Result.MD ?? candidate.Station.MD ?? candidate.Station.Abscissa ?? double.MaxValue)
            .ToList();
        HashSet<int> selectedIndexes = [];
        for (int sampleIndex = 0; sampleIndex < MaxDisplayedUncertaintyEllipses; sampleIndex++)
        {
            int sourceIndex = (int)Math.Round(sampleIndex * (ordered.Count - 1.0) / (MaxDisplayedUncertaintyEllipses - 1.0));
            selectedIndexes.Add(Math.Clamp(sourceIndex, 0, ordered.Count - 1));
        }
        selectedIndexes.Add(ordered.Count - 1);
        return selectedIndexes.Order().Select(index => ordered[index]).ToList();
    }

    private static FieldModelShared.SurveyStation? FindStation(ICollection<FieldModelShared.SurveyStation> surveyStations, double? md)
    {
        if (md is not { } definedMd)
        {
            return null;
        }

        return surveyStations
            .Where(station => station != null && (station.MD ?? station.Abscissa) is { })
            .OrderBy(station => Math.Abs(((station.MD ?? station.Abscissa) ?? double.MaxValue) - definedMd))
            .FirstOrDefault();
    }

    private static PlotTrace? BuildHorizontalEllipseTrace(FieldModelShared.SurveyStation station, FieldModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, string? surveyRunName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double major = semiMajor * Math.Cos(phi);
            double minor = semiMinor * Math.Sin(phi);
            double northOffset = major * Math.Cos(angle) - minor * Math.Sin(angle);
            double eastOffset = major * Math.Sin(angle) + minor * Math.Cos(angle);
            northValues.Add(centerNorth + northOffset);
            eastValues.Add(centerEast + eastOffset);
            tvdValues.Add(centerTvd);
        }

        return new PlotTrace($"{surveyRunName ?? "survey run"} horizontal ellipses", 1, color, showLegend, northValues, eastValues, tvdValues, false, true);
    }

    private static PlotTrace? BuildPerpendicularEllipseTrace(FieldModelShared.SurveyStation station, FieldModelShared.SurveyStationEllipse? ellipse, string color, bool showLegend, string? surveyRunName)
    {
        if (ellipse?.SemiMajorAxis is not double semiMajor ||
            ellipse.SemiMinorAxis is not double semiMinor ||
            ellipse.OrientationAngle is not double angle ||
            station.Inclination is not double inclination ||
            station.Azimuth is not double azimuth ||
            station.X is not double centerNorth ||
            station.Y is not double centerEast)
        {
            return null;
        }

        double centerTvd = station.TVD ?? station.Z ?? 0.0;
        double cosA = Math.Cos(azimuth);
        double sinA = Math.Sin(azimuth);
        double cosI = Math.Cos(inclination);
        double sinI = Math.Sin(inclination);
        double cosO = Math.Cos(angle);
        double sinO = Math.Sin(angle);
        List<object> northValues = [];
        List<object> eastValues = [];
        List<object> tvdValues = [];
        for (int i = 0; i <= EllipsePointCount; i++)
        {
            double phi = 2.0 * Math.PI * i / EllipsePointCount;
            double localX0 = semiMajor * Math.Cos(phi);
            double localY0 = semiMinor * Math.Sin(phi);
            double localX = localX0 * cosO - localY0 * sinO;
            double localY = localX0 * sinO + localY0 * cosO;
            northValues.Add(centerNorth + cosA * cosI * localX - sinA * localY);
            eastValues.Add(centerEast + sinA * cosI * localX + cosA * localY);
            tvdValues.Add(centerTvd - sinI * localX);
        }

        return new PlotTrace($"{surveyRunName ?? "survey run"} perpendicular ellipses", 1, color, showLegend, northValues, eastValues, tvdValues, true, false);
    }


    private static void AppendPoint(FieldModelShared.SurveyStation? point, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (point?.X is not { } north || point.Y is not { } east)
        {
            return;
        }

        double tvd = point.TVD ?? point.Z ?? 0.0;
        AppendPointValues(north, east, tvd, northValues, eastValues, tvdValues);
    }

    private static void AppendPointValues(double north, double east, double tvd, List<object> northValues, List<object> eastValues, List<object> tvdValues)
    {
        if (northValues.Count > 0 &&
            eastValues.Count == northValues.Count &&
            tvdValues.Count == northValues.Count &&
            TryGetLastDouble(northValues, out double lastNorth) &&
            TryGetLastDouble(eastValues, out double lastEast) &&
            TryGetLastDouble(tvdValues, out double lastTvd) &&
            AreClose(lastNorth, north) &&
            AreClose(lastEast, east) &&
            AreClose(lastTvd, tvd))
        {
            return;
        }

        northValues.Add(north);
        eastValues.Add(east);
        tvdValues.Add(tvd);
    }

    private static bool TryGetLastDouble(List<object> values, out double value)
    {
        value = default;
        if (values.Count == 0)
        {
            return false;
        }

        object last = values[^1];
        return last switch
        {
            double d => (value = d) == d,
            float f => (value = f) == f,
            decimal m => (value = (double)m) == (double)m,
            int i => (value = i) == i,
            long l => (value = l) == l,
            _ => false
        };
    }

    private static bool TryGetDouble(object value, out double converted)
    {
        converted = default;
        return value switch
        {
            double d => (converted = d) == d,
            float f => (converted = f) == f,
            decimal m => (converted = (double)m) == (double)m,
            int i => (converted = i) == i,
            long l => (converted = l) == l,
            _ => false
        };
    }

    private static bool AreClose(double left, double right)
    {
        return Math.Abs(left - right) <= 1e-6;
    }

