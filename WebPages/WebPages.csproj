<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <RootNamespace>NORCE.Drilling.Field.WebPages</RootNamespace>
    <PackageId>NORCE.Drilling.Field.WebPages</PackageId>
    <Title>NORCE.Drilling.Field.WebPages</Title>
    <Authors>Eric Cayeux</Authors>
    <Company>NORCE</Company>
    <Description>Reusable Razor class library containing the Field, CartographicConverter, and statistics web pages. See the package README for setup, dependencies, and usage.</Description>
    <PackageTags>field;drilling;blazor;razor;mudblazor</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/Open-Source-Drilling-Community/Field</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/Open-Source-Drilling-Community/Field</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MudBlazor" Version="8.14.0" />
    <PackageReference Include="OSDC.DotnetLibraries.Drilling.WebAppUtils" Version="1.1.0" />
    <PackageReference Include="OSDC.DotnetLibraries.General.DataManagement" Version="2.1.0" />
    <PackageReference Include="OSDC.UnitConversion.DrillingRazorMudComponents" Version="3.3.47" />
  </ItemGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

	<!-- Include generated DTO source files directly from ModelSharedOut -->
	<ItemGroup>
		<Compile Include="..\ModelSharedOut\FieldMergedModel.cs"
				 Link="GeneratedDtos\%(RecursiveDir)%(Filename)%(Extension)" />
	</ItemGroup>

</Project>
